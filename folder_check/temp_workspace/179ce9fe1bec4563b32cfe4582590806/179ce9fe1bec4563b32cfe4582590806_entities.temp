{"Level_3_Foundations": [{"id": "fb89bcc2f30a4bbbad7c7de97d41ddff_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "fb89bcc2f30a4bbbad7c7de97d41ddff_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "fb89bcc2f30a4bbbad7c7de97d41ddff_e3", "label": "SUBJECT", "name": "Tổ chức kinh tế có vốn đầu tư nước ngoài", "value": "Tổ chức kinh tế có vốn đầu tư nước ngoài."}, {"id": "fb89bcc2f30a4bbbad7c7de97d41ddff_e4", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận về quyền sử dụng đất và sở hữu tài sản", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "fb89bcc2f30a4bbbad7c7de97d41ddff_e1", "type": "DEFINES", "target": "fb89bcc2f30a4bbbad7c7de97d41ddff_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "7", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "fb89bcc2f30a4bbbad7c7de97d41ddff"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n7. Tổ chức kinh tế có vốn đầu tư nước ngoài."}
{"Level_3_Foundations": [{"id": "9ddfdb3f067948bb86bc99e9d33996c2_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "9ddfdb3f067948bb86bc99e9d33996c2_e2", "label": "SUBJECT", "name": "Người sử dụng đất liền kề và xung quanh", "value": "người sử dụng đất liền kề và xung quanh"}], "Level_2_Rules_Actions": [{"id": "9ddfdb3f067948bb86bc99e9d33996c2_e3", "label": "RIGHT_OBLIGATION", "name": "Thực hiện quyền và nghĩa vụ trong thời hạn sử dụng đất", "value": "Thực hiện quyền và nghĩa vụ của người sử dụng đất trong thời hạn sử dụng đất theo quy định của Luật này và quy định khác của pháp luật có liên quan"}, {"id": "9ddfdb3f067948bb86bc99e9d33996c2_e4", "label": "PROHIBITED_EXCLUDED", "name": "Không xâm phạm quyền, lợi ích hợp pháp của người sử dụng đất liền kề và xung quanh", "value": "không xâm phạm quyền, lợi ích hợp pháp của người sử dụng đất liền kề và xung quanh"}], "Attributes_Measures": [{"id": "9ddfdb3f067948bb86bc99e9d33996c2_e5", "label": "TIME_DURATION", "name": "Trong thời hạn sử dụng đất", "value": "trong thời hạn sử dụng đất"}], "Relationships": [{"source": "9ddfdb3f067948bb86bc99e9d33996c2_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "9ddfdb3f067948bb86bc99e9d33996c2_e3"}, {"source": "9ddfdb3f067948bb86bc99e9d33996c2_e1", "type": "IS_PROHIBITED_OR_EXCLUDED", "target": "9ddfdb3f067948bb86bc99e9d33996c2_e4"}, {"source": "9ddfdb3f067948bb86bc99e9d33996c2_e3", "type": "HAS_DURATION", "target": "9ddfdb3f067948bb86bc99e9d33996c2_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "5", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9ddfdb3f067948bb86bc99e9d33996c2"}, "original_content": "Điều 5. Nguyên tắc sử dụng đất\n4. Thực hiện quyền và nghĩa vụ của người sử dụng đất trong thời hạn sử dụng đất theo quy định của Luật này và quy định khác của pháp luật có liên quan; không xâm phạm quyền, lợi ích hợp pháp của người sử dụng đất liền kề và xung quanh."}
{"Level_3_Foundations": [{"id": "781d29e32cbd4aacb5891d2dbc41fa99_e1", "label": "SUBJECT", "name": "Chủ thể sử dụng đất", "value": "Chủ thể sử dụng đất"}, {"id": "781d29e32cbd4aacb5891d2dbc41fa99_e2", "label": "LEGAL_CONCEPT", "name": "Nguyên tắc sử dụng đất", "value": "Nguyên tắc sử dụng đất"}, {"id": "781d29e32cbd4aacb5891d2dbc41fa99_e3", "label": "OBJECT_EQUIPMENT", "name": "Thuốc bảo vệ thực vật, phân hóa học", "value": "thuốc bảo vệ thực vật, phân hóa học"}], "Level_2_Rules_Actions": [{"id": "781d29e32cbd4aacb5891d2dbc41fa99_e4", "label": "RIGHT_OBLIGATION", "name": "Bảo vệ đất, môi trường, thích ứng biến đổi khí hậu", "value": "Bảo vệ đất, bảo vệ môi trường, thích ứng với biến đổi khí hậu"}, {"id": "781d29e32cbd4aacb5891d2dbc41fa99_e5", "label": "PROHIBITED_EXCLUDED", "name": "Lạm dụng thuốc bảo vệ thực vật, phân hóa học làm ô nhiễm, thoái hóa đất", "value": "không được lạm dụng thuốc bảo vệ thực vật, phân hóa học làm ô nhiễm, thoái hóa đất"}], "Attributes_Measures": [], "Relationships": [{"source": "781d29e32cbd4aacb5891d2dbc41fa99_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "781d29e32cbd4aacb5891d2dbc41fa99_e4"}, {"source": "781d29e32cbd4aacb5891d2dbc41fa99_e1", "type": "IS_PROHIBITED_OR_EXCLUDED", "target": "781d29e32cbd4aacb5891d2dbc41fa99_e5"}, {"source": "781d29e32cbd4aacb5891d2dbc41fa99_e5", "type": "APPLIES_TO_OBJECT", "target": "781d29e32cbd4aacb5891d2dbc41fa99_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "5", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "781d29e32cbd4aacb5891d2dbc41fa99"}, "original_content": "Điều 5. Nguyên tắc sử dụng đất\n3. Bảo vệ đất, bảo vệ môi trường, thích ứng với biến đổi khí hậu, không được lạm dụng thuốc bảo vệ thực vật, phân hóa học làm ô nhiễm, thoái hóa đất."}
{"Level_3_Foundations": [{"id": "f4beb0bb73d84c9d952ddaaafd33ab24_e1", "label": "STANDARD_CONDITION", "name": "Sử dụng đất bền vững, tiết kiệm, hiệu quả", "value": "Bền vững, tiết kiệm, có hiệu quả đối với đất đai và tài nguyên trên bề mặt, trong lòng đất."}, {"id": "f4beb0bb73d84c9d952ddaaafd33ab24_e2", "label": "OBJECT_EQUIPMENT", "name": "Đất đai và tài nguyên", "value": "đất đai và tài nguyên trên bề mặt, trong lòng đất"}, {"id": "f4beb0bb73d84c9d952ddaaafd33ab24_e3", "label": "LEGAL_CONCEPT", "name": "Nguyên tắc sử dụng đất", "value": "Nguyên tắc sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "f4beb0bb73d84c9d952ddaaafd33ab24_e1", "type": "APPLIES_TO_OBJECT", "target": "f4beb0bb73d84c9d952ddaaafd33ab24_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "5", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "f4beb0bb73d84c9d952ddaaafd33ab24"}, "original_content": "Điều 5. Nguyên tắc sử dụng đất\n2. Bền vững, tiết kiệm, có hiệu quả đối với đất đai và tài nguyên trên bề mặt, trong lòng đất."}
{"Level_3_Foundations": [{"id": "2a093070fb554972be79d305db8fa4d5_e1", "label": "SUBJECT", "name": "Chủ tịch Ủy ban nhân dân cấp xã", "value": "Chủ tịch Ủy ban nhân dân cấp xã"}, {"id": "2a093070fb554972be79d305db8fa4d5_e2", "label": "OBJECT_EQUIPMENT", "name": "Đất nông nghiệp sử dụng vào mục đích công ích", "value": "đất nông nghiệp vào mục đích công ích"}, {"id": "2a093070fb554972be79d305db8fa4d5_e3", "label": "OBJECT_EQUIPMENT", "name": "Đất phi nông nghiệp giao cho Ủy ban nhân dân cấp xã", "value": "đất phi nông nghiệp đã giao cho Ủy ban nhân dân cấp xã để sử dụng vào mục đích xây dựng trụ sở Ủy ban nhân dân, các công trình công cộng phục vụ hoạt động văn hóa, giáo dục, y tế, thể dục, thể thao, vui chơi, giải trí, chợ, nghĩa trang và công trình công cộng khác của xã, phường, thị trấn"}, {"id": "2a093070fb554972be79d305db8fa4d5_e4", "label": "OBJECT_EQUIPMENT", "name": "Đất tôn giáo, đất tín ngưỡng chưa giao quản lý, sử dụng", "value": "đất tôn giáo, đất tín ngưỡng chưa giao quản lý, sử dụng"}], "Level_2_Rules_Actions": [{"id": "2a093070fb554972be79d305db8fa4d5_e5", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất", "value": "chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất"}], "Attributes_Measures": [], "Relationships": [{"source": "2a093070fb554972be79d305db8fa4d5_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "2a093070fb554972be79d305db8fa4d5_e5"}, {"source": "2a093070fb554972be79d305db8fa4d5_e5", "type": "APPLIES_TO_OBJECT", "target": "2a093070fb554972be79d305db8fa4d5_e2"}, {"source": "2a093070fb554972be79d305db8fa4d5_e5", "type": "APPLIES_TO_OBJECT", "target": "2a093070fb554972be79d305db8fa4d5_e3"}, {"source": "2a093070fb554972be79d305db8fa4d5_e5", "type": "APPLIES_TO_OBJECT", "target": "2a093070fb554972be79d305db8fa4d5_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "2a093070fb554972be79d305db8fa4d5"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n2. Chủ tịch Ủy ban nhân dân cấp xã đối với việc sử dụng đất nông nghiệp vào mục đích công ích; đất phi nông nghiệp đã giao cho Ủy ban nhân dân cấp xã để sử dụng vào mục đích xây dựng trụ sở Ủy ban nhân dân, các công trình công cộng phục vụ hoạt động văn hóa, giáo dục, y tế, thể dục, thể thao, vui chơi, giải trí, chợ, nghĩa trang và công trình công cộng khác của xã, phường, thị trấn; đất tôn giáo, đất tín ngưỡng chưa giao quản lý, sử dụng."}
{"Level_3_Foundations": [{"id": "1aae4e45afa94227957a8c3e55a6c83a_e1", "label": "SUBJECT", "name": "Người đại diện theo pháp luật của tổ chức", "value": "Người đại diện theo pháp luật của tổ chức trong nước, tổ chức kinh tế có vốn đầu tư nước ngoài"}, {"id": "1aae4e45afa94227957a8c3e55a6c83a_e2", "label": "SUBJECT", "name": "Người đứng đầu của tổ chức nước ngoài có chức năng ngoại giao", "value": "người đứng đầu của tổ chức nước ngoài có chức năng ngoại giao"}, {"id": "1aae4e45afa94227957a8c3e55a6c83a_e3", "label": "DOCUMENT_RECORD", "name": "Điều 6, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất"}], "Level_2_Rules_Actions": [{"id": "1aae4e45afa94227957a8c3e55a6c83a_e4", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước về việc sử dụng đất của tổ chức", "value": "chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất của tổ chức mình"}], "Attributes_Measures": [], "Relationships": [{"source": "1aae4e45afa94227957a8c3e55a6c83a_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "1aae4e45afa94227957a8c3e55a6c83a_e4"}, {"source": "1aae4e45afa94227957a8c3e55a6c83a_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "1aae4e45afa94227957a8c3e55a6c83a_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "1aae4e45afa94227957a8c3e55a6c83a"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n1. Người đại diện theo pháp luật của tổ chức trong nước, tổ chức kinh tế có vốn đầu tư nước ngoài; người đứng đầu của tổ chức nước ngoài có chức năng ngoại giao đối với việc sử dụng đất của tổ chức mình."}
{"Level_3_Foundations": [{"id": "2b91b594ebf0484191815a4e3c9c60dc_e1", "label": "LEGAL_CONCEPT", "name": "Người đại diện cho cộng đồng dân cư", "value": "Người đại diện cho cộng đồng dân cư"}, {"id": "2b91b594ebf0484191815a4e3c9c60dc_e2", "label": "DEFINITION", "name": "Định nghĩa người đại diện cho cộng đồng dân cư", "value": "Người đại diện cho cộng đồng dân cư là trưởng thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự hoặc người được cộng đồng dân cư thỏa thuận cử ra."}, {"id": "2b91b594ebf0484191815a4e3c9c60dc_e3", "label": "SUBJECT", "name": "Trưởng thôn, làng, ấp, bản và các điểm dân cư tương tự", "value": "trưởng thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự"}, {"id": "2b91b594ebf0484191815a4e3c9c60dc_e4", "label": "SUBJECT", "name": "Người được cộng đồng dân cư thỏa thuận cử ra", "value": "người được cộng đồng dân cư thỏa thuận cử ra"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "2b91b594ebf0484191815a4e3c9c60dc_e1", "type": "DEFINES", "target": "2b91b594ebf0484191815a4e3c9c60dc_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "2b91b594ebf0484191815a4e3c9c60dc"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n3. Người đại diện cho cộng đồng dân cư là trưởng thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự hoặc người được cộng đồng dân cư thỏa thuận cử ra."}
{"Level_3_Foundations": [{"id": "aa150c3a03144a71b91868d64e0b1204_e1", "label": "SUBJECT", "name": "Cá nhân, người gốc Việt Nam định cư ở nước ngoài", "value": "Cá nhân, người gốc Việt Nam định cư ở nước ngoài"}, {"id": "aa150c3a03144a71b91868d64e0b1204_e3", "label": "DOCUMENT_RECORD", "name": "Điều 6, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n5. Cá nhân, người gốc Việt Nam định cư ở nước ngoài đối với việc sử dụng đất của mình."}], "Level_2_Rules_Actions": [{"id": "aa150c3a03144a71b91868d64e0b1204_e2", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất của mình", "value": "chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất của mình"}], "Attributes_Measures": [], "Relationships": [{"source": "aa150c3a03144a71b91868d64e0b1204_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "aa150c3a03144a71b91868d64e0b1204_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "aa150c3a03144a71b91868d64e0b1204"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n5. Cá nhân, người gốc Việt Nam định cư ở nước ngoài đối với việc sử dụng đất của mình."}
{"Level_3_Foundations": [{"id": "5d7675755574447c876253a47761d7e4_e1", "label": "SUBJECT", "name": "Người đại diện tổ chức tôn giáo, tổ chức tôn giáo trực thuộc", "value": "Người đại diện tổ chức tôn giáo, tổ chức tôn giáo trực thuộc"}], "Level_2_Rules_Actions": [{"id": "5d7675755574447c876253a47761d7e4_e2", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất của tổ chức tôn giáo", "value": "chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất của tổ chức tôn giáo, tổ chức tôn giáo trực thuộc"}], "Attributes_Measures": [], "Relationships": [{"source": "5d7675755574447c876253a47761d7e4_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "5d7675755574447c876253a47761d7e4_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5d7675755574447c876253a47761d7e4"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n4. Người đại diện tổ chức tôn giáo, tổ chức tôn giáo trực thuộc đối với việc sử dụng đất của tổ chức tôn giáo, tổ chức tôn giáo trực thuộc."}
{"Level_3_Foundations": [{"id": "804f3883ca5f4766811b5a9ad3f7d381_e1", "label": "SUBJECT", "name": "Người có chung quyền sử dụng đất hoặc người đại diện", "value": "Người có chung quyền sử dụng đất hoặc người đại diện cho nhóm người có chung quyền sử dụng đất"}], "Level_2_Rules_Actions": [{"id": "804f3883ca5f4766811b5a9ad3f7d381_e2", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất", "value": "chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất đó"}], "Attributes_Measures": [], "Relationships": [{"source": "804f3883ca5f4766811b5a9ad3f7d381_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "804f3883ca5f4766811b5a9ad3f7d381_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "6", "khoan": "6", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "804f3883ca5f4766811b5a9ad3f7d381"}, "original_content": "Điều 6. Người chịu trách nhiệm trước Nhà nước đối với việc sử dụng đất\n6. Người có chung quyền sử dụng đất hoặc người đại diện cho nhóm người có chung quyền sử dụng đất đối với việc sử dụng đất đó."}
{"Level_3_Foundations": [{"id": "eca654def45545f9b3998a3b362f8c85_e1", "label": "DOCUMENT_RECORD", "name": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}, {"id": "eca654def45545f9b3998a3b362f8c85_e2", "label": "SUBJECT", "name": "Người đại diện của tổ chức", "value": "Người đại diện của tổ chức"}, {"id": "eca654def45545f9b3998a3b362f8c85_e3", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "eca654def45545f9b3998a3b362f8c85_e4", "label": "OBJECT_EQUIPMENT", "name": "Công trình công cộng", "value": "công trình công cộng"}, {"id": "eca654def45545f9b3998a3b362f8c85_e5", "label": "OBJECT_EQUIPMENT", "name": "Hành lang bảo vệ an toàn các công trình", "value": "hành lang bảo vệ an toàn các công trình"}], "Level_2_Rules_Actions": [{"id": "eca654def45545f9b3998a3b362f8c85_e6", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm đối với việc quản lý đất", "value": "chịu trách nhiệm đối với việc quản lý đất"}, {"id": "eca654def45545f9b3998a3b362f8c85_e7", "label": "RIGHT_OBLIGATION", "name": "Được giao quản lý công trình công cộng và hành lang bảo vệ an toàn", "value": "được giao quản lý công trình công cộng và hành lang bảo vệ an toàn các công trình theo quy định của pháp luật"}], "Attributes_Measures": [], "Relationships": [{"source": "eca654def45545f9b3998a3b362f8c85_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "eca654def45545f9b3998a3b362f8c85_e6"}, {"source": "eca654def45545f9b3998a3b362f8c85_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "eca654def45545f9b3998a3b362f8c85_e7"}, {"source": "eca654def45545f9b3998a3b362f8c85_e7", "type": "APPLIES_TO_OBJECT", "target": "eca654def45545f9b3998a3b362f8c85_e4"}, {"source": "eca654def45545f9b3998a3b362f8c85_e7", "type": "APPLIES_TO_OBJECT", "target": "eca654def45545f9b3998a3b362f8c85_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "1", "diem": "a", "type": "LEGAL_RULE", "chunk_uuid": "eca654def45545f9b3998a3b362f8c85"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\na) Tổ chức trong nước được giao quản lý công trình công cộng và hành lang bảo vệ an toàn các công trình theo quy định của pháp luật;"}
{"Level_3_Foundations": [{"id": "6aed365118cf49669d766072e92bec86_e1", "label": "SUBJECT", "name": "Người đại diện của tổ chức", "value": "Người đại diện của tổ chức"}, {"id": "6aed365118cf49669d766072e92bec86_e2", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "6aed365118cf49669d766072e92bec86_e3", "label": "STANDARD_CONDITION", "name": "Được giao quản lý quỹ đất đã thu hồi", "value": "được giao quản lý quỹ đất đã thu hồi theo quyết định của cơ quan nhà nước có thẩm quyền"}, {"id": "6aed365118cf49669d766072e92bec86_e4", "label": "DOCUMENT_RECORD", "name": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}], "Level_2_Rules_Actions": [{"id": "6aed365118cf49669d766072e92bec86_e5", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}, {"id": "6aed365118cf49669d766072e92bec86_e6", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm đối với việc quản lý đất", "value": "chịu trách nhiệm đối với việc quản lý đất"}], "Attributes_Measures": [], "Relationships": [{"source": "6aed365118cf49669d766072e92bec86_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "6aed365118cf49669d766072e92bec86_e5"}, {"source": "6aed365118cf49669d766072e92bec86_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "6aed365118cf49669d766072e92bec86_e6"}, {"source": "6aed365118cf49669d766072e92bec86_e2", "type": "MEETS_CONDITION", "target": "6aed365118cf49669d766072e92bec86_e3"}, {"source": "6aed365118cf49669d766072e92bec86_e6", "type": "APPLIES_TO_OBJECT", "target": "6aed365118cf49669d766072e92bec86_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "1", "diem": "c", "type": "LEGAL_RULE", "chunk_uuid": "6aed365118cf49669d766072e92bec86"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\nc) Tổ chức trong nước được giao quản lý quỹ đất đã thu hồi theo quyết định của cơ quan nhà nước có thẩm quyền;"}
{"Level_3_Foundations": [{"id": "c5f394651d214809b28524502e8093b1_e1", "label": "SUBJECT", "name": "Người đại diện của tổ chức", "value": "Người đại diện của tổ chức"}, {"id": "c5f394651d214809b28524502e8093b1_e2", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "c5f394651d214809b28524502e8093b1_e3", "label": "OBJECT_EQUIPMENT", "name": "Đất có mặt nước của các sông và đất có mặt nước chuyên dùng", "value": "đất có mặt nước của các sông và đất có mặt nước chuyên dùng"}, {"id": "c5f394651d214809b28524502e8093b1_e4", "label": "STANDARD_CONDITION", "name": "Được giao quản lý đất có mặt nước của các sông và đất có mặt nước chuyên dùng", "value": "được giao quản lý đất có mặt nước của các sông và đất có mặt nước chuyên dùng"}, {"id": "c5f394651d214809b28524502e8093b1_e5", "label": "LEGAL_CONCEPT", "name": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}, {"id": "c5f394651d214809b28524502e8093b1_e6", "label": "DOCUMENT_RECORD", "name": "Điều 7, Khoản 1, Điểm b, Văn bản 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\nb) Tổ chức trong nước được giao quản lý đất có mặt nước của các sông và đất có mặt nước chuyên dùng;"}], "Level_2_Rules_Actions": [{"id": "c5f394651d214809b28524502e8093b1_e7", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm quản lý đất", "value": "chịu trách nhiệm đối với việc quản lý đất"}], "Attributes_Measures": [], "Relationships": [{"source": "c5f394651d214809b28524502e8093b1_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "c5f394651d214809b28524502e8093b1_e7"}, {"source": "c5f394651d214809b28524502e8093b1_e7", "type": "MEETS_CONDITION", "target": "c5f394651d214809b28524502e8093b1_e4"}, {"source": "c5f394651d214809b28524502e8093b1_e2", "type": "MEETS_CONDITION", "target": "c5f394651d214809b28524502e8093b1_e4"}, {"source": "c5f394651d214809b28524502e8093b1_e4", "type": "APPLIES_TO_OBJECT", "target": "c5f394651d214809b28524502e8093b1_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "1", "diem": "b", "type": "LEGAL_RULE", "chunk_uuid": "c5f394651d214809b28524502e8093b1"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\nb) Tổ chức trong nước được giao quản lý đất có mặt nước của các sông và đất có mặt nước chuyên dùng;"}
{"Level_3_Foundations": [{"id": "11bd63a90d7d48c8adad63da2a50aeda_e1", "label": "SUBJECT", "name": "Chủ tịch Ủy ban nhân dân cấp tỉnh", "value": "Chủ tịch Ủy ban nhân dân cấp tỉnh"}, {"id": "11bd63a90d7d48c8adad63da2a50aeda_e2", "label": "OBJECT_EQUIPMENT", "name": "Đất chưa sử dụng tại các đảo chưa giao quản lý", "value": "đất chưa sử dụng tại các đảo chưa giao cho đơn vị hành chính cấp huyện, cấp xã quản lý"}, {"id": "11bd63a90d7d48c8adad63da2a50aeda_e3", "label": "DOCUMENT_RECORD", "name": "Điều 7, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}], "Level_2_Rules_Actions": [{"id": "11bd63a90d7d48c8adad63da2a50aeda_e4", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm quản lý đất chưa sử dụng tại các đảo chưa giao quản lý", "value": "chịu trách nhiệm đối với việc quản lý đất chưa sử dụng tại các đảo chưa giao cho đơn vị hành chính cấp huyện, cấp xã quản lý"}], "Attributes_Measures": [], "Relationships": [{"source": "11bd63a90d7d48c8adad63da2a50aeda_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "11bd63a90d7d48c8adad63da2a50aeda_e4"}, {"source": "11bd63a90d7d48c8adad63da2a50aeda_e4", "type": "APPLIES_TO_OBJECT", "target": "11bd63a90d7d48c8adad63da2a50aeda_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "11bd63a90d7d48c8adad63da2a50aeda"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n3. Chủ tịch Ủy ban nhân dân cấp tỉnh chịu trách nhiệm đối với việc quản lý đất chưa sử dụng tại các đảo chưa giao cho đơn vị hành chính cấp huyện, cấp xã quản lý."}
{"Level_3_Foundations": [{"id": "8d3f3efa2398498f86d0caf4aac030ad_e1", "label": "SUBJECT", "name": "Chủ tịch Ủy ban nhân dân cấp xã, cấp huyện", "value": "Chủ tịch Ủy ban nhân dân cấp xã, Chủ tịch Ủy ban nhân dân cấp huyện nơi không thành lập đơn vị hành chính cấp xã"}, {"id": "8d3f3efa2398498f86d0caf4aac030ad_e2", "label": "OBJECT_EQUIPMENT", "name": "Đất công cộng, đất chưa giao, đất chưa cho thuê", "value": "đất sử dụng vào mục đích công cộng được giao quản lý, đất chưa giao, đất chưa cho thuê tại địa phương"}, {"id": "8d3f3efa2398498f86d0caf4aac030ad_e3", "label": "LEGAL_CONCEPT", "name": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}, {"id": "8d3f3efa2398498f86d0caf4aac030ad_e4", "label": "DOCUMENT_RECORD", "name": "Điều 7, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}], "Level_2_Rules_Actions": [{"id": "8d3f3efa2398498f86d0caf4aac030ad_e5", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm quản lý đất công cộng, đất chưa giao, đất chưa cho thuê", "value": "chịu trách nhiệm đối với việc quản lý đất sử dụng vào mục đích công cộng được giao quản lý, đất chưa giao, đất chưa cho thuê tại địa phương"}], "Attributes_Measures": [], "Relationships": [{"source": "8d3f3efa2398498f86d0caf4aac030ad_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "8d3f3efa2398498f86d0caf4aac030ad_e5"}, {"source": "8d3f3efa2398498f86d0caf4aac030ad_e5", "type": "APPLIES_TO_OBJECT", "target": "8d3f3efa2398498f86d0caf4aac030ad_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "8d3f3efa2398498f86d0caf4aac030ad"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n2. Chủ tịch Ủy ban nhân dân cấp xã, Chủ tịch Ủy ban nhân dân cấp huyện nơi không thành lập đơn vị hành chính cấp xã chịu trách nhiệm đối với việc quản lý đất sử dụng vào mục đích công cộng được giao quản lý, đất chưa giao, đất chưa cho thuê tại địa phương."}
{"Level_3_Foundations": [{"id": "a40b756c87c3498fa9730850b163b877_e1", "label": "SUBJECT", "name": "Người đại diện của tổ chức", "value": "Người đại diện của tổ chức"}, {"id": "a40b756c87c3498fa9730850b163b877_e2", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "Tổ chức kinh tế"}, {"id": "a40b756c87c3498fa9730850b163b877_e3", "label": "LEGAL_CONCEPT", "name": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý", "value": "Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý"}, {"id": "a40b756c87c3498fa9730850b163b877_e4", "label": "STANDARD_CONDITION", "name": "Được giao quản lý diện tích đất để thực hiện dự án đầu tư", "value": "được giao quản lý diện tích đất để thực hiện dự án đầu tư theo quy định của pháp luật"}, {"id": "a40b756c87c3498fa9730850b163b877_e5", "label": "DOCUMENT_RECORD", "name": "Điều 7, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\nd) Tổ chức kinh tế được giao quản lý diện tích đất để thực hiện dự án đầu tư theo quy định của pháp luật."}], "Level_2_Rules_Actions": [{"id": "a40b756c87c3498fa9730850b163b877_e6", "label": "RIGHT_OBLIGATION", "name": "Chịu trách nhiệm đối với việc quản lý đất", "value": "chịu trách nhiệm đối với việc quản lý đất"}], "Attributes_Measures": [], "Relationships": [{"source": "a40b756c87c3498fa9730850b163b877_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "a40b756c87c3498fa9730850b163b877_e6"}, {"source": "a40b756c87c3498fa9730850b163b877_e2", "type": "MEETS_CONDITION", "target": "a40b756c87c3498fa9730850b163b877_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "7", "khoan": "1", "diem": "d", "type": "LEGAL_RULE", "chunk_uuid": "a40b756c87c3498fa9730850b163b877"}, "original_content": "Điều 7. Người chịu trách nhiệm trước Nhà nước đối với đất được giao quản lý\n1. Người đại diện của tổ chức chịu trách nhiệm đối với việc quản lý đất trong các trường hợp sau đây:\nd) Tổ chức kinh tế được giao quản lý diện tích đất để thực hiện dự án đầu tư theo quy định của pháp luật."}
