{"Level_3_Foundations": [{"id": "c26d2e2c4c8e4502b537af0e625fdfa8_e1", "label": "SUBJECT", "name": "Quốc hội", "value": "Quốc hội"}, {"id": "c26d2e2c4c8e4502b537af0e625fdfa8_e2", "label": "DOCUMENT_RECORD", "name": "Luật Đất đai số 31/2024/QH15", "value": "Luật số: 31/2024/QH15, LUẬT ĐẤT ĐAI"}, {"id": "c26d2e2c4c8e4502b537af0e625fdfa8_e3", "label": "DOCUMENT_RECORD", "name": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam", "value": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam"}], "Level_2_Rules_Actions": [{"id": "c26d2e2c4c8e4502b537af0e625fdfa8_e4", "label": "PROCEDURE_ACTION", "name": "Ban hành Luật Đất đai", "value": "ban hành Luật Đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "c26d2e2c4c8e4502b537af0e625fdfa8_e1", "type": "EXECUTES_ACTION", "target": "c26d2e2c4c8e4502b537af0e625fdfa8_e4"}, {"source": "c26d2e2c4c8e4502b537af0e625fdfa8_e4", "type": "MEETS_CONDITION", "target": "c26d2e2c4c8e4502b537af0e625fdfa8_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "Phần mở đầu", "khoan": null, "diem": null, "type": "PREAMBLE", "chunk_uuid": "c26d2e2c4c8e4502b537af0e625fdfa8"}, "original_content": "**QUỐC HỘI**\n**CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM**\n**Độc lập - Tự do - Hạnh phúc**\nLuật số: 31/2024/QH15\n\n**LUẬT**\n**ĐẤT ĐAI**\n\nCăn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam;\nQuốc hội ban hành Luật Đất đai.\n\n## Chương I\n**QUY ĐỊNH CHUNG**"}
{"Level_3_Foundations": [{"id": "0713f1548aa048ffa4b94047a2b58d5e_e1", "label": "DOCUMENT_RECORD", "name": "Điều 1 Luật Đất đai - Phạm vi điều chỉnh", "value": "Luật này quy định về chế độ sở hữu đất đai, quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai, chế độ quản lý và sử dụng đất đai, quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam."}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e2", "label": "LEGAL_CONCEPT", "name": "Chế độ sở hữu đất đai", "value": "chế độ sở hữu đất đai"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e4", "label": "LEGAL_CONCEPT", "name": "Chế độ quản lý và sử dụng đất đai", "value": "chế độ quản lý và sử dụng đất đai"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e5", "label": "SUBJECT", "name": "Công dân", "value": "công dân"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e6", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e7", "label": "OBJECT_EQUIPMENT", "name": "Đất đai thuộc lãnh thổ Việt Nam", "value": "đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam"}], "Level_2_Rules_Actions": [{"id": "0713f1548aa048ffa4b94047a2b58d5e_e8", "label": "RIGHT_OBLIGATION", "name": "Quyền hạn và trách nhiệm của Nhà nước về đất đai", "value": "quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai"}, {"id": "0713f1548aa048ffa4b94047a2b58d5e_e9", "label": "RIGHT_OBLIGATION", "name": "Quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai", "value": "quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "0713f1548aa048ffa4b94047a2b58d5e_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "0713f1548aa048ffa4b94047a2b58d5e_e8"}, {"source": "0713f1548aa048ffa4b94047a2b58d5e_e5", "type": "HAS_RIGHT_OBLIGATION", "target": "0713f1548aa048ffa4b94047a2b58d5e_e9"}, {"source": "0713f1548aa048ffa4b94047a2b58d5e_e6", "type": "HAS_RIGHT_OBLIGATION", "target": "0713f1548aa048ffa4b94047a2b58d5e_e9"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "1", "khoan": null, "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "0713f1548aa048ffa4b94047a2b58d5e"}, "original_content": "Điều 1. Phạm vi điều chỉnh\nLuật này quy định về chế độ sở hữu đất đai, quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai, chế độ quản lý và sử dụng đất đai, quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "86ee323370d14b7e89bb6cb1d79ea758_e1", "label": "SUBJECT", "name": "Cơ quan nhà nước", "value": "Cơ quan nhà nước"}, {"id": "86ee323370d14b7e89bb6cb1d79ea758_e2", "label": "OBJECT_EQUIPMENT", "name": "Đất đai", "value": "đất đai"}, {"id": "86ee323370d14b7e89bb6cb1d79ea758_e3", "label": "SUBJECT", "name": "Chủ sở hữu toàn dân", "value": "chủ sở hữu toàn dân"}], "Level_2_Rules_Actions": [{"id": "86ee323370d14b7e89bb6cb1d79ea758_e4", "label": "RIGHT_OBLIGATION", "name": "Đại diện chủ sở hữu toàn dân về đất đai", "value": "thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai"}, {"id": "86ee323370d14b7e89bb6cb1d79ea758_e5", "label": "RIGHT_OBLIGATION", "name": "Thống nhất quản lý nhà nước về đất đai", "value": "thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "86ee323370d14b7e89bb6cb1d79ea758_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "86ee323370d14b7e89bb6cb1d79ea758_e4"}, {"source": "86ee323370d14b7e89bb6cb1d79ea758_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "86ee323370d14b7e89bb6cb1d79ea758_e5"}, {"source": "86ee323370d14b7e89bb6cb1d79ea758_e4", "type": "APPLIES_TO_OBJECT", "target": "86ee323370d14b7e89bb6cb1d79ea758_e2"}, {"source": "86ee323370d14b7e89bb6cb1d79ea758_e5", "type": "APPLIES_TO_OBJECT", "target": "86ee323370d14b7e89bb6cb1d79ea758_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "86ee323370d14b7e89bb6cb1d79ea758"}, "original_content": "Điều 2. Đối tượng áp dụng\n1. Cơ quan nhà nước thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai, thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai."}
{"Level_3_Foundations": [{"id": "da0ba8b06fd045119f09395455d299e9_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "da0ba8b06fd045119f09395455d299e9"}, "original_content": "Điều 2. Đối tượng áp dụng\n2. Người sử dụng đất."}
{"Level_3_Foundations": [{"id": "5790215316c949609e0b7e911fc6029a_e1", "label": "SUBJECT", "name": "Đối tượng khác liên quan đến quản lý, sử dụng đất đai", "value": "Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5790215316c949609e0b7e911fc6029a"}, "original_content": "Điều 2. Đối tượng áp dụng\n3. Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}
{"Level_3_Foundations": [{"id": "282611bed6b04c77bb8ef3dd9a0debdc_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ địa chính", "value": "Bản đồ địa chính"}, {"id": "282611bed6b04c77bb8ef3dd9a0debdc_e2", "label": "DEFINITION", "name": "Định nghĩa bản đồ địa chính", "value": "Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "282611bed6b04c77bb8ef3dd9a0debdc_e1", "type": "DEFINES", "target": "282611bed6b04c77bb8ef3dd9a0debdc_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "282611bed6b04c77bb8ef3dd9a0debdc"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n1. Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}
{"Level_3_Foundations": [{"id": "7f486d2a727e42d79aa1e6ad7f76a7d5_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "7f486d2a727e42d79aa1e6ad7f76a7d5_e2", "label": "LEGAL_CONCEPT", "name": "Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất"}, {"id": "7f486d2a727e42d79aa1e6ad7f76a7d5_e3", "label": "DEFINITION", "name": "Định nghĩa Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "7f486d2a727e42d79aa1e6ad7f76a7d5_e2", "type": "DEFINES", "target": "7f486d2a727e42d79aa1e6ad7f76a7d5_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "7f486d2a727e42d79aa1e6ad7f76a7d5"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n2. Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}
{"Level_3_Foundations": [{"id": "8c3dd105bab24a00a6716f913d50e5f9_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất"}, {"id": "8c3dd105bab24a00a6716f913d50e5f9_e2", "label": "DEFINITION", "name": "Định nghĩa Bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "8c3dd105bab24a00a6716f913d50e5f9_e1", "type": "DEFINES", "target": "8c3dd105bab24a00a6716f913d50e5f9_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "8c3dd105bab24a00a6716f913d50e5f9"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n3. Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}
{"Level_3_Foundations": [{"id": "e61c6e79135b41bdbf7ee0d79da57bce_e1", "label": "LEGAL_CONCEPT", "name": "Bảo vệ, cải tạo, phục hồi đất", "value": "Bảo vệ, cải tạo, phục hồi đất"}, {"id": "e61c6e79135b41bdbf7ee0d79da57bce_e2", "label": "DEFINITION", "name": "Định nghĩa về bảo vệ, cải tạo, phục hồi đất", "value": "Bảo vệ, cải tạo, phục hồi đất là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e61c6e79135b41bdbf7ee0d79da57bce_e1", "type": "DEFINES", "target": "e61c6e79135b41bdbf7ee0d79da57bce_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e61c6e79135b41bdbf7ee0d79da57bce"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n4. Bảo vệ, cải tạo, phục hồi đất là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}
{"Level_3_Foundations": [{"id": "9d33c3f762104c0f8f76a00810811c6d_e1", "label": "LEGAL_CONCEPT", "name": "Bồi thường về đất", "value": "Bồi thường về đất"}, {"id": "9d33c3f762104c0f8f76a00810811c6d_e2", "label": "DEFINITION", "name": "Định nghĩa bồi thường về đất", "value": "Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "9d33c3f762104c0f8f76a00810811c6d_e1", "type": "DEFINES", "target": "9d33c3f762104c0f8f76a00810811c6d_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9d33c3f762104c0f8f76a00810811c6d"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n5. Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}
{"Level_3_Foundations": [{"id": "9c7905565ded450fb4f0bdf5ad692f10_e1", "label": "LEGAL_CONCEPT", "name": "Chi phí đầu tư vào đất còn lại", "value": "Chi phí đầu tư vào đất còn lại"}, {"id": "9c7905565ded450fb4f0bdf5ad692f10_e2", "label": "DEFINITION", "name": "Định nghĩa chi phí đầu tư vào đất còn lại", "value": "là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}, {"id": "9c7905565ded450fb4f0bdf5ad692f10_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "9c7905565ded450fb4f0bdf5ad692f10_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "9c7905565ded450fb4f0bdf5ad692f10_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3 Khoản 7 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}], "Level_2_Rules_Actions": [{"id": "9c7905565ded450fb4f0bdf5ad692f10_e6", "label": "PROCEDURE_ACTION", "name": "Đầu tư trực tiếp vào đất", "value": "đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất"}, {"id": "9c7905565ded450fb4f0bdf5ad692f10_e7", "label": "PROCEDURE_ACTION", "name": "Thu hồi đất", "value": "thu hồi đất"}], "Attributes_Measures": [], "Relationships": [{"source": "9c7905565ded450fb4f0bdf5ad692f10_e1", "type": "DEFINES", "target": "9c7905565ded450fb4f0bdf5ad692f10_e2"}, {"source": "9c7905565ded450fb4f0bdf5ad692f10_e3", "type": "EXECUTES_ACTION", "target": "9c7905565ded450fb4f0bdf5ad692f10_e6"}, {"source": "9c7905565ded450fb4f0bdf5ad692f10_e4", "type": "EXECUTES_ACTION", "target": "9c7905565ded450fb4f0bdf5ad692f10_e7"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "7", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9c7905565ded450fb4f0bdf5ad692f10"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}
{"Level_3_Foundations": [{"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e1", "label": "LEGAL_CONCEPT", "name": "Cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e2", "label": "DEFINITION", "name": "Định nghĩa Cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e3", "label": "SUBJECT", "name": "Cá nhân", "value": "cá nhân"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e4", "label": "STANDARD_CONDITION", "name": "Được Nhà nước giao, cho thuê, công nhận quyền sử dụng đất nông nghiệp", "value": "đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e5", "label": "STANDARD_CONDITION", "name": "Nhận chuyển quyền sử dụng đất nông nghiệp", "value": "nhận chuyển quyền sử dụng đất nông nghiệp"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e6", "label": "STANDARD_CONDITION", "name": "Có thu nhập từ sản xuất nông nghiệp trên đất", "value": "có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e7", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e8", "label": "SUBJECT", "name": "Chính phủ", "value": "Chính phủ"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e9", "label": "OBJECT_EQUIPMENT", "name": "Đất nông nghiệp", "value": "đất nông nghiệp"}, {"id": "ef72f8ec2d024c7a9d07d5a203db92a2_e10", "label": "DOCUMENT_RECORD", "name": "Điều 3, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n6. Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e1", "type": "DEFINES", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e2"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e3", "type": "MEETS_CONDITION", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e4"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e3", "type": "MEETS_CONDITION", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e5"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e3", "type": "MEETS_CONDITION", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e6"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e4", "type": "APPLIES_TO_OBJECT", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e9"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e5", "type": "APPLIES_TO_OBJECT", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e9"}, {"source": "ef72f8ec2d024c7a9d07d5a203db92a2_e6", "type": "APPLIES_TO_OBJECT", "target": "ef72f8ec2d024c7a9d07d5a203db92a2_e9"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "6", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "ef72f8ec2d024c7a9d07d5a203db92a2"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n6. Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}
{"Level_3_Foundations": [{"id": "5830194c32d04708842ee466a01e5aa5_e1", "label": "LEGAL_CONCEPT", "name": "Chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất"}, {"id": "5830194c32d04708842ee466a01e5aa5_e2", "label": "DEFINITION", "name": "Định nghĩa Chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "5830194c32d04708842ee466a01e5aa5_e1", "type": "DEFINES", "target": "5830194c32d04708842ee466a01e5aa5_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "8", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5830194c32d04708842ee466a01e5aa5"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n8. Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}
{"Level_3_Foundations": [{"id": "becb4d5d3eb64d4ba2313d03cd12d642_e1", "label": "LEGAL_CONCEPT", "name": "Chiếm đất", "value": "Chiếm đất"}, {"id": "becb4d5d3eb64d4ba2313d03cd12d642_e2", "label": "DEFINITION", "name": "Định nghĩa chiếm đất", "value": "là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}, {"id": "becb4d5d3eb64d4ba2313d03cd12d642_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "becb4d5d3eb64d4ba2313d03cd12d642_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "becb4d5d3eb64d4ba2313d03cd12d642_e5", "label": "SUBJECT", "name": "Người sử dụng đất hợp pháp khác", "value": "người sử dụng đất hợp pháp khác"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "becb4d5d3eb64d4ba2313d03cd12d642_e1", "type": "DEFINES", "target": "becb4d5d3eb64d4ba2313d03cd12d642_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "9", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "becb4d5d3eb64d4ba2313d03cd12d642"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n9. Chiếm đất là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}
{"Level_3_Foundations": [{"id": "622358870aa4473c955a338d97aaa6c1_e1", "label": "LEGAL_CONCEPT", "name": "Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư)"}, {"id": "622358870aa4473c955a338d97aaa6c1_e2", "label": "DEFINITION", "name": "Định nghĩa Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}, {"id": "622358870aa4473c955a338d97aaa6c1_e3", "label": "STANDARD_CONDITION", "name": "Là nhà đầu tư theo quy định của pháp luật", "value": "là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan"}, {"id": "622358870aa4473c955a338d97aaa6c1_e4", "label": "STANDARD_CONDITION", "name": "Được lựa chọn để thực hiện dự án đầu tư có sử dụng đất", "value": "đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất"}, {"id": "622358870aa4473c955a338d97aaa6c1_e5", "label": "STANDARD_CONDITION", "name": "Được giao đất, cho thuê đất, chuyển mục đích sử dụng đất", "value": "được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này"}, {"id": "622358870aa4473c955a338d97aaa6c1_e6", "label": "OBJECT_EQUIPMENT", "name": "Dự án đầu tư có sử dụng đất", "value": "dự án đầu tư có sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "622358870aa4473c955a338d97aaa6c1_e1", "type": "DEFINES", "target": "622358870aa4473c955a338d97aaa6c1_e2"}, {"source": "622358870aa4473c955a338d97aaa6c1_e1", "type": "MEETS_CONDITION", "target": "622358870aa4473c955a338d97aaa6c1_e3"}, {"source": "622358870aa4473c955a338d97aaa6c1_e1", "type": "MEETS_CONDITION", "target": "622358870aa4473c955a338d97aaa6c1_e4"}, {"source": "622358870aa4473c955a338d97aaa6c1_e1", "type": "MEETS_CONDITION", "target": "622358870aa4473c955a338d97aaa6c1_e5"}, {"source": "622358870aa4473c955a338d97aaa6c1_e4", "type": "APPLIES_TO_OBJECT", "target": "622358870aa4473c955a338d97aaa6c1_e6"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "10", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "622358870aa4473c955a338d97aaa6c1"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n10. Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư) là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "a1ef6252344a4ab38dfc1112993014b0_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "a1ef6252344a4ab38dfc1112993014b0_e2", "label": "LEGAL_CONCEPT", "name": "Chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất"}, {"id": "a1ef6252344a4ab38dfc1112993014b0_e3", "label": "DEFINITION", "name": "Định nghĩa Chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a1ef6252344a4ab38dfc1112993014b0_e2", "type": "DEFINES", "target": "a1ef6252344a4ab38dfc1112993014b0_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "12", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a1ef6252344a4ab38dfc1112993014b0"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n12. Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}
{"Level_3_Foundations": [{"id": "5042f26e036746e7bfb9d0c7fdbd6c14_e1", "label": "LEGAL_CONCEPT", "name": "Cộng đồng dân cư", "value": "Cộng đồng dân cư"}, {"id": "5042f26e036746e7bfb9d0c7fdbd6c14_e2", "label": "DEFINITION", "name": "Định nghĩa Cộng đồng dân cư", "value": "Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "5042f26e036746e7bfb9d0c7fdbd6c14_e1", "type": "DEFINES", "target": "5042f26e036746e7bfb9d0c7fdbd6c14_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "13", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5042f26e036746e7bfb9d0c7fdbd6c14"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n13. Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "4338190c2e4d41cebb82452d1435b103_e1", "label": "LEGAL_CONCEPT", "name": "Chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất"}, {"id": "4338190c2e4d41cebb82452d1435b103_e2", "label": "DEFINITION", "name": "Định nghĩa chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}, {"id": "4338190c2e4d41cebb82452d1435b103_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "4338190c2e4d41cebb82452d1435b103_e4", "label": "STANDARD_CONDITION", "name": "Theo quy định của Luật này", "value": "theo quy định của Luật này"}], "Level_2_Rules_Actions": [{"id": "4338190c2e4d41cebb82452d1435b103_e5", "label": "PROCEDURE_ACTION", "name": "Thay đổi mục đích sử dụng đất", "value": "thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác"}], "Attributes_Measures": [], "Relationships": [{"source": "4338190c2e4d41cebb82452d1435b103_e1", "type": "DEFINES", "target": "4338190c2e4d41cebb82452d1435b103_e2"}, {"source": "4338190c2e4d41cebb82452d1435b103_e3", "type": "EXECUTES_ACTION", "target": "4338190c2e4d41cebb82452d1435b103_e5"}, {"source": "4338190c2e4d41cebb82452d1435b103_e5", "type": "MEETS_CONDITION", "target": "4338190c2e4d41cebb82452d1435b103_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "11", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "4338190c2e4d41cebb82452d1435b103"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n11. Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "6e2d909a7bce48e7916712091ba5b1c4_e1", "label": "LEGAL_CONCEPT", "name": "Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai"}, {"id": "6e2d909a7bce48e7916712091ba5b1c4_e2", "label": "DEFINITION", "name": "Định nghĩa Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "6e2d909a7bce48e7916712091ba5b1c4_e1", "type": "DEFINES", "target": "6e2d909a7bce48e7916712091ba5b1c4_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "14", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "6e2d909a7bce48e7916712091ba5b1c4"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n14. Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}
{"Level_3_Foundations": [{"id": "eceb1dd2b64c42da8a98242afb9c74ca_e1", "label": "LEGAL_CONCEPT", "name": "Đất đang có tranh chấp", "value": "Đất đang có tranh chấp"}, {"id": "eceb1dd2b64c42da8a98242afb9c74ca_e2", "label": "DEFINITION", "name": "Định nghĩa đất đang có tranh chấp", "value": "Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}, {"id": "eceb1dd2b64c42da8a98242afb9c74ca_e3", "label": "SUBJECT", "name": "Cơ quan có thẩm quyền", "value": "cơ quan có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "eceb1dd2b64c42da8a98242afb9c74ca_e1", "type": "DEFINES", "target": "eceb1dd2b64c42da8a98242afb9c74ca_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "16", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "eceb1dd2b64c42da8a98242afb9c74ca"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n16. Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}
{"Level_3_Foundations": [{"id": "e938da9b820a4284a4f903e12d335d1b_e1", "label": "LEGAL_CONCEPT", "name": "Đăng ký đất đai, tài sản gắn liền với đất", "value": "Đăng ký đất đai, tài sản gắn liền với đất"}, {"id": "e938da9b820a4284a4f903e12d335d1b_e2", "label": "DEFINITION", "name": "Định nghĩa về Đăng ký đất đai, tài sản gắn liền với đất", "value": "Đăng ký đất đai, tài sản gắn liền với đất là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}, {"id": "e938da9b820a4284a4f903e12d335d1b_e3", "label": "SUBJECT", "name": "Người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất", "value": "người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất"}, {"id": "e938da9b820a4284a4f903e12d335d1b_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [{"id": "e938da9b820a4284a4f903e12d335d1b_e5", "label": "PROCEDURE_ACTION", "name": "Kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này"}], "Attributes_Measures": [], "Relationships": [{"source": "e938da9b820a4284a4f903e12d335d1b_e1", "type": "DEFINES", "target": "e938da9b820a4284a4f903e12d335d1b_e2"}, {"source": "e938da9b820a4284a4f903e12d335d1b_e3", "type": "EXECUTES_ACTION", "target": "e938da9b820a4284a4f903e12d335d1b_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "15", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e938da9b820a4284a4f903e12d335d1b"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n15. Đăng ký đất đai, tài sản gắn liền với đất là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "b8c78cd4bf7146cda86be79ddacf5b02_e1", "label": "LEGAL_CONCEPT", "name": "Giá đất", "value": "Giá đất"}, {"id": "b8c78cd4bf7146cda86be79ddacf5b02_e2", "label": "DEFINITION", "name": "Định nghĩa giá đất", "value": "Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "b8c78cd4bf7146cda86be79ddacf5b02_e1", "type": "DEFINES", "target": "b8c78cd4bf7146cda86be79ddacf5b02_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "19", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "b8c78cd4bf7146cda86be79ddacf5b02"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n19. Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}
{"Level_3_Foundations": [{"id": "6519d2955fc0407f87b484c696bedba8_e1", "label": "LEGAL_CONCEPT", "name": "Điều chỉnh thời hạn sử dụng đất", "value": "Điều chỉnh thời hạn sử dụng đất"}, {"id": "6519d2955fc0407f87b484c696bedba8_e2", "label": "DEFINITION", "name": "Định nghĩa điều chỉnh thời hạn sử dụng đất", "value": "Điều chỉnh thời hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}, {"id": "6519d2955fc0407f87b484c696bedba8_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [{"id": "6519d2955fc0407f87b484c696bedba8_e4", "label": "PROCEDURE_ACTION", "name": "Cho phép thay đổi thời hạn sử dụng đất", "value": "cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất"}], "Attributes_Measures": [], "Relationships": [{"source": "6519d2955fc0407f87b484c696bedba8_e1", "type": "DEFINES", "target": "6519d2955fc0407f87b484c696bedba8_e2"}, {"source": "6519d2955fc0407f87b484c696bedba8_e3", "type": "EXECUTES_ACTION", "target": "6519d2955fc0407f87b484c696bedba8_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "17", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "6519d2955fc0407f87b484c696bedba8"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n17. Điều chỉnh thời hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}
{"Level_3_Foundations": [{"id": "6429a2a2519c4becac930ed17e9947f4_e1", "label": "LEGAL_CONCEPT", "name": "Gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất"}, {"id": "6429a2a2519c4becac930ed17e9947f4_e2", "label": "DEFINITION", "name": "Định nghĩa gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}, {"id": "6429a2a2519c4becac930ed17e9947f4_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "6429a2a2519c4becac930ed17e9947f4_e1", "type": "DEFINES", "target": "6429a2a2519c4becac930ed17e9947f4_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "18", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "6429a2a2519c4becac930ed17e9947f4"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n18. Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "8f9ccbfcf522447e9433af3ae8637eac_e1", "label": "LEGAL_CONCEPT", "name": "Giá trị quyền sử dụng đất", "value": "Giá trị quyền sử dụng đất"}, {"id": "8f9ccbfcf522447e9433af3ae8637eac_e2", "label": "DEFINITION", "name": "Định nghĩa giá trị quyền sử dụng đất", "value": "Giá trị quyền sử dụng đất là giá trị bằng tiền của quyền sử dụng đất đối với một diện tích đất, loại đất tại thời điểm được xác định với thời hạn sử dụng đã được xác định."}, {"id": "8f9ccbfcf522447e9433af3ae8637eac_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3 Khoản 20 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ. 20. Giá trị quyền sử dụng đất là giá trị bằng tiền của quyền sử dụng đất đối với một diện tích đất, loại đất tại thời điểm được xác định với thời hạn sử dụng đã được xác định."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "8f9ccbfcf522447e9433af3ae8637eac_e1", "type": "DEFINES", "target": "8f9ccbfcf522447e9433af3ae8637eac_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "20", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "8f9ccbfcf522447e9433af3ae8637eac"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n20. Giá trị quyền sử dụng đất là giá trị bằng tiền của quyền sử dụng đất đối với một diện tích đất, loại đất tại thời điểm được xác định với thời hạn sử dụng đã được xác định."}
{"Level_3_Foundations": [{"id": "268e8bc9e66a4825a71897a5d3cc89bd_e1", "label": "LEGAL_CONCEPT", "name": "Góp vốn bằng quyền sử dụng đất", "value": "Góp vốn bằng quyền sử dụng đất"}, {"id": "268e8bc9e66a4825a71897a5d3cc89bd_e2", "label": "DEFINITION", "name": "Định nghĩa Góp vốn bằng quyền sử dụng đất", "value": "Góp vốn bằng quyền sử dụng đất là sự thỏa thuận giữa các bên về chuyển quyền sử dụng đất thông qua việc góp quyền sử dụng đất để tạo thành vốn điều lệ của tổ chức kinh tế, bao gồm góp vốn để thành lập tổ chức kinh tế hoặc góp thêm vốn điều lệ của tổ chức kinh tế đã được thành lập."}, {"id": "268e8bc9e66a4825a71897a5d3cc89bd_e3", "label": "SUBJECT", "name": "Các bên trong thỏa thuận góp vốn", "value": "các bên"}, {"id": "268e8bc9e66a4825a71897a5d3cc89bd_e4", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "tổ chức kinh tế"}, {"id": "268e8bc9e66a4825a71897a5d3cc89bd_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 22, Luật 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n22. Góp vốn bằng quyền sử dụng đất là sự thỏa thuận giữa các bên về chuyển quyền sử dụng đất thông qua việc góp quyền sử dụng đất để tạo thành vốn điều lệ của tổ chức kinh tế, bao gồm góp vốn để thành lập tổ chức kinh tế hoặc góp thêm vốn điều lệ của tổ chức kinh tế đã được thành lập."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "268e8bc9e66a4825a71897a5d3cc89bd_e1", "type": "DEFINES", "target": "268e8bc9e66a4825a71897a5d3cc89bd_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "22", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "268e8bc9e66a4825a71897a5d3cc89bd"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n22. Góp vốn bằng quyền sử dụng đất là sự thỏa thuận giữa các bên về chuyển quyền sử dụng đất thông qua việc góp quyền sử dụng đất để tạo thành vốn điều lệ của tổ chức kinh tế, bao gồm góp vốn để thành lập tổ chức kinh tế hoặc góp thêm vốn điều lệ của tổ chức kinh tế đã được thành lập."}
{"Level_3_Foundations": [{"id": "944a68827ee842a689fc5073ce22c164_e1", "label": "LEGAL_CONCEPT", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "944a68827ee842a689fc5073ce22c164_e2", "label": "DEFINITION", "name": "Định nghĩa Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là chứng thư pháp lý để Nhà nước xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp của người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất."}, {"id": "944a68827ee842a689fc5073ce22c164_e3", "label": "STANDARD_CONDITION", "name": "Tài sản gắn liền với đất được cấp Giấy chứng nhận", "value": "Tài sản gắn liền với đất được cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là nhà ở, công trình xây dựng gắn liền với đất theo quy định của pháp luật."}, {"id": "944a68827ee842a689fc5073ce22c164_e4", "label": "OBJECT_EQUIPMENT", "name": "Nhà ở, công trình xây dựng gắn liền với đất", "value": "nhà ở, công trình xây dựng gắn liền với đất"}, {"id": "944a68827ee842a689fc5073ce22c164_e5", "label": "STANDARD_CONDITION", "name": "Giá trị pháp lý tương đương của các loại Giấy chứng nhận khác", "value": "Giấy chứng nhận về quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất theo quy định của các luật có liên quan được thực hiện theo quy định của Luật này có giá trị pháp lý tương đương như Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất tại Luật này."}, {"id": "944a68827ee842a689fc5073ce22c164_e6", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "944a68827ee842a689fc5073ce22c164_e7", "label": "SUBJECT", "name": "Người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "944a68827ee842a689fc5073ce22c164_e1", "type": "DEFINES", "target": "944a68827ee842a689fc5073ce22c164_e2"}, {"source": "944a68827ee842a689fc5073ce22c164_e1", "type": "MEETS_CONDITION", "target": "944a68827ee842a689fc5073ce22c164_e3"}, {"source": "944a68827ee842a689fc5073ce22c164_e3", "type": "APPLIES_TO_OBJECT", "target": "944a68827ee842a689fc5073ce22c164_e4"}, {"source": "944a68827ee842a689fc5073ce22c164_e1", "type": "MEETS_CONDITION", "target": "944a68827ee842a689fc5073ce22c164_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "21", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "944a68827ee842a689fc5073ce22c164"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n21. Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là chứng thư pháp lý để Nhà nước xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp của người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất. Tài sản gắn liền với đất được cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là nhà ở, công trình xây dựng gắn liền với đất theo quy định của pháp luật. Giấy chứng nhận về quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất theo quy định của các luật có\n\nliên quan được thực hiện theo quy định của Luật này có giá trị pháp lý tương đương như Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất tại Luật này."}
{"Level_3_Foundations": [{"id": "123627fcacee48208126264db2c97a44_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "123627fcacee48208126264db2c97a44_e2", "label": "LEGAL_CONCEPT", "name": "Hệ thống thông tin quốc gia về đất đai", "value": "Hệ thống thông tin quốc gia về đất đai"}, {"id": "123627fcacee48208126264db2c97a44_e3", "label": "DEFINITION", "name": "Định nghĩa Hệ thống thông tin quốc gia về đất đai", "value": "Hệ thống thông tin quốc gia về đất đai là hệ thống tổng hợp các yếu tố hạ tầng kỹ thuật công nghệ thông tin, phần mềm, dữ liệu được xây dựng thành một hệ thống tập trung, thống nhất trên phạm vi cả nước để quản lý, vận hành, cập nhật, khai thác thông tin đất đai."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "123627fcacee48208126264db2c97a44_e2", "type": "DEFINES", "target": "123627fcacee48208126264db2c97a44_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "23", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "123627fcacee48208126264db2c97a44"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n23. Hệ thống thông tin quốc gia về đất đai là hệ thống tổng hợp các yếu tố hạ tầng kỹ thuật công nghệ thông tin, phần mềm, dữ liệu được xây dựng thành một hệ thống tập trung, thống nhất trên phạm vi cả nước để quản lý, vận hành, cập nhật, khai thác thông tin đất đai."}
{"Level_3_Foundations": [{"id": "63d1269f9e814b0a974907a141947f52_e1", "label": "LEGAL_CONCEPT", "name": "Hỗ trợ khi Nhà nước thu hồi đất", "value": "Hỗ trợ khi Nhà nước thu hồi đất"}, {"id": "63d1269f9e814b0a974907a141947f52_e2", "label": "DEFINITION", "name": "Định nghĩa Hỗ trợ khi Nhà nước thu hồi đất", "value": "Hỗ trợ khi Nhà nước thu hồi đất là chính sách của Nhà nước nhằm trợ giúp cho người có đất thu hồi, chủ sở hữu tài sản gắn liền với đất để ổn định đời sống, sản xuất và phát triển ngoài các khoản đã bồi thường theo quy định của Luật này."}, {"id": "63d1269f9e814b0a974907a141947f52_e3", "label": "SUBJECT", "name": "Người có đất thu hồi", "value": "người có đất thu hồi"}, {"id": "63d1269f9e814b0a974907a141947f52_e4", "label": "SUBJECT", "name": "Chủ sở hữu tài sản gắn liền với đất", "value": "chủ sở hữu tài sản gắn liền với đất"}, {"id": "63d1269f9e814b0a974907a141947f52_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "63d1269f9e814b0a974907a141947f52_e1", "type": "DEFINES", "target": "63d1269f9e814b0a974907a141947f52_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "24", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "63d1269f9e814b0a974907a141947f52"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n24. Hỗ trợ khi Nhà nước thu hồi đất là chính sách của Nhà nước nhằm trợ giúp cho người có đất thu hồi, chủ sở hữu tài sản gắn liền với đất để ổn định đời sống, sản xuất và phát triển ngoài các khoản đã bồi thường theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "a44c8d84cd8c46c28a954d952b9d603f_e1", "label": "LEGAL_CONCEPT", "name": "Hộ gia đình sử dụng đất", "value": "Hộ gia đình sử dụng đất"}, {"id": "a44c8d84cd8c46c28a954d952b9d603f_e2", "label": "DEFINITION", "name": "Định nghĩa Hộ gia đình sử dụng đất", "value": "Hộ gia đình sử dụng đất là những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình, đang sống chung và có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất trước ngày Luật này có hiệu lực thi hành."}, {"id": "a44c8d84cd8c46c28a954d952b9d603f_e3", "label": "STANDARD_CONDITION", "name": "Có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo pháp luật", "value": "những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình"}, {"id": "a44c8d84cd8c46c28a954d952b9d603f_e4", "label": "STANDARD_CONDITION", "name": "Đang sống chung", "value": "đang sống chung"}, {"id": "a44c8d84cd8c46c28a954d952b9d603f_e5", "label": "STANDARD_CONDITION", "name": "Có quyền sử dụng đất chung tại thời điểm được Nhà nước giao, cho thuê, công nhận, nhận chuyển quyền sử dụng đất", "value": "có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất"}, {"id": "a44c8d84cd8c46c28a954d952b9d603f_e6", "label": "STANDARD_CONDITION", "name": "Trước ngày Luật này có hiệu lực thi hành", "value": "trước ngày Luật này có hiệu lực thi hành"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a44c8d84cd8c46c28a954d952b9d603f_e1", "type": "DEFINES", "target": "a44c8d84cd8c46c28a954d952b9d603f_e2"}, {"source": "a44c8d84cd8c46c28a954d952b9d603f_e1", "type": "MEETS_CONDITION", "target": "a44c8d84cd8c46c28a954d952b9d603f_e3"}, {"source": "a44c8d84cd8c46c28a954d952b9d603f_e1", "type": "MEETS_CONDITION", "target": "a44c8d84cd8c46c28a954d952b9d603f_e4"}, {"source": "a44c8d84cd8c46c28a954d952b9d603f_e1", "type": "MEETS_CONDITION", "target": "a44c8d84cd8c46c28a954d952b9d603f_e5"}, {"source": "a44c8d84cd8c46c28a954d952b9d603f_e1", "type": "MEETS_CONDITION", "target": "a44c8d84cd8c46c28a954d952b9d603f_e6"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "25", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a44c8d84cd8c46c28a954d952b9d603f"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n25. Hộ gia đình sử dụng đất là những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình, đang sống chung và có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất trước ngày Luật này có hiệu lực thi hành."}
{"Level_3_Foundations": [{"id": "c58d6df5e2984161be28e77abbb37398_e1", "label": "LEGAL_CONCEPT", "name": "Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất", "value": "Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất"}, {"id": "c58d6df5e2984161be28e77abbb37398_e2", "label": "DEFINITION", "name": "Định nghĩa hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất", "value": "Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất là sự thỏa thuận giữa các bên, theo đó người sử dụng đất dùng quyền sử dụng đất của mình để hợp tác sản xuất, kinh doanh mà không làm thay đổi quyền sử dụng đất của người sử dụng đất."}, {"id": "c58d6df5e2984161be28e77abbb37398_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "c58d6df5e2984161be28e77abbb37398_e1", "type": "DEFINES", "target": "c58d6df5e2984161be28e77abbb37398_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "26", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "c58d6df5e2984161be28e77abbb37398"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n26. Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất là sự thỏa thuận giữa các bên, theo đó người sử dụng đất dùng quyền sử dụng đất của mình để hợp tác sản xuất, kinh doanh mà không làm thay đổi quyền sử dụng đất của người sử dụng đất."}
{"Level_3_Foundations": [{"id": "f07977862e574121becd6e57f2ba03f8_e1", "label": "LEGAL_CONCEPT", "name": "Hủy hoại đất", "value": "Hủy hoại đất"}, {"id": "f07977862e574121becd6e57f2ba03f8_e2", "label": "DEFINITION", "name": "Định nghĩa Hủy hoại đất", "value": "Hủy hoại đất là hành vi làm biến dạng địa hình, làm suy giảm chất lượng đất, gây ô nhiễm đất mà làm mất hoặc giảm khả năng sử dụng đất theo mục đích đã được xác định."}, {"id": "f07977862e574121becd6e57f2ba03f8_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "f07977862e574121becd6e57f2ba03f8_e1", "type": "DEFINES", "target": "f07977862e574121becd6e57f2ba03f8_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "27", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "f07977862e574121becd6e57f2ba03f8"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n27. Hủy hoại đất là hành vi làm biến dạng địa hình, làm suy giảm chất lượng đất, gây ô nhiễm đất mà làm mất hoặc giảm khả năng sử dụng đất theo mục đích đã được xác định."}
{"Level_3_Foundations": [{"id": "e326f298269441149220ecab2b0bbd78_e1", "label": "LEGAL_CONCEPT", "name": "Kế hoạch sử dụng đất", "value": "Kế hoạch sử dụng đất"}, {"id": "e326f298269441149220ecab2b0bbd78_e2", "label": "DEFINITION", "name": "Định nghĩa Kế hoạch sử dụng đất", "value": "Kế hoạch sử dụng đất là việc phân kỳ quy hoạch sử dụng đất theo thời gian để thực hiện."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e326f298269441149220ecab2b0bbd78_e1", "type": "DEFINES", "target": "e326f298269441149220ecab2b0bbd78_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "28", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e326f298269441149220ecab2b0bbd78"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n28. Kế hoạch sử dụng đất là việc phân kỳ quy hoạch sử dụng đất theo thời gian để thực hiện."}
{"Level_3_Foundations": [{"id": "e2fd56a2924f48ea9ae58e17873d497f_e1", "label": "LEGAL_CONCEPT", "name": "Lấn biển", "value": "Lấn biển"}, {"id": "e2fd56a2924f48ea9ae58e17873d497f_e2", "label": "DEFINITION", "name": "Định nghĩa lấn biển", "value": "Lấn biển là việc mở rộng diện tích đất trong phạm vi từ đường mép nước biển thấp nhất trung bình trong nhiều năm về phía biển thuộc vùng biển Việt Nam."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e2fd56a2924f48ea9ae58e17873d497f_e1", "type": "DEFINES", "target": "e2fd56a2924f48ea9ae58e17873d497f_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "30", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e2fd56a2924f48ea9ae58e17873d497f"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n30. Lấn biển là việc mở rộng diện tích đất trong phạm vi từ đường mép nước biển thấp nhất trung bình trong nhiều năm về phía biển thuộc vùng biển Việt Nam."}
{"Level_3_Foundations": [{"id": "e72ab740fd544bcb97a3fa8b10402131_e1", "label": "LEGAL_CONCEPT", "name": "Lấn đất", "value": "Lấn đất"}, {"id": "e72ab740fd544bcb97a3fa8b10402131_e2", "label": "DEFINITION", "name": "Định nghĩa lấn đất", "value": "Lấn đất là việc người sử dụng đất chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng mà không được cơ quan nhà nước có thẩm quyền cho phép hoặc không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép."}, {"id": "e72ab740fd544bcb97a3fa8b10402131_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "e72ab740fd544bcb97a3fa8b10402131_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e72ab740fd544bcb97a3fa8b10402131_e1", "type": "DEFINES", "target": "e72ab740fd544bcb97a3fa8b10402131_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "31", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e72ab740fd544bcb97a3fa8b10402131"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n31. Lấn đất là việc người sử dụng đất chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng mà không được cơ quan nhà nước có thẩm quyền cho phép hoặc không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép."}
{"Level_3_Foundations": [{"id": "c04f59a2d83a400a95cf595fa9df9045_e1", "label": "LEGAL_CONCEPT", "name": "Kiểm kê đất đai", "value": "Kiểm kê đất đai"}, {"id": "c04f59a2d83a400a95cf595fa9df9045_e2", "label": "DEFINITION", "name": "Định nghĩa Kiểm kê đất đai", "value": "Kiểm kê đất đai là việc Nhà nước tổ chức điều tra, tổng hợp, đánh giá trên hồ sơ địa chính và trên thực địa về hiện trạng sử dụng đất tại thời điểm kiểm kê và biến động đất đai giữa 02 lần kiểm kê."}, {"id": "c04f59a2d83a400a95cf595fa9df9045_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "c04f59a2d83a400a95cf595fa9df9045_e4", "label": "OBJECT_EQUIPMENT", "name": "Hồ sơ địa chính và thực địa", "value": "hồ sơ địa chính và trên thực địa"}], "Level_2_Rules_Actions": [{"id": "c04f59a2d83a400a95cf595fa9df9045_e5", "label": "PROCEDURE_ACTION", "name": "Tổ chức điều tra, tổng hợp, đánh giá về hiện trạng sử dụng đất", "value": "tổ chức điều tra, tổng hợp, đánh giá trên hồ sơ địa chính và trên thực địa về hiện trạng sử dụng đất tại thời điểm kiểm kê và biến động đất đai giữa 02 lần kiểm kê"}], "Attributes_Measures": [], "Relationships": [{"source": "c04f59a2d83a400a95cf595fa9df9045_e1", "type": "DEFINES", "target": "c04f59a2d83a400a95cf595fa9df9045_e2"}, {"source": "c04f59a2d83a400a95cf595fa9df9045_e3", "type": "EXECUTES_ACTION", "target": "c04f59a2d83a400a95cf595fa9df9045_e5"}, {"source": "c04f59a2d83a400a95cf595fa9df9045_e5", "type": "APPLIES_TO_OBJECT", "target": "c04f59a2d83a400a95cf595fa9df9045_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "29", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "c04f59a2d83a400a95cf595fa9df9045"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n29. Kiểm kê đất đai là việc Nhà nước tổ chức điều tra, tổng hợp, đánh giá trên hồ sơ địa chính và trên thực địa về hiện trạng sử dụng đất tại thời điểm kiểm kê và biến động đất đai giữa 02 lần kiểm kê."}
{"Level_3_Foundations": [{"id": "dd43de8f68764883b6e1fbab75777cab_e1", "label": "LEGAL_CONCEPT", "name": "Nhà nước cho thuê quyền sử dụng đất", "value": "Nhà nước cho thuê quyền sử dụng đất (sau đây gọi là Nhà nước cho thuê đất)"}, {"id": "dd43de8f68764883b6e1fbab75777cab_e2", "label": "DEFINITION", "name": "Định nghĩa Nhà nước cho thuê đất", "value": "việc cơ quan nhà nước có thẩm quyền ban hành quyết định cho thuê đất cho đối tượng có nhu cầu sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "dd43de8f68764883b6e1fbab75777cab_e1", "type": "DEFINES", "target": "dd43de8f68764883b6e1fbab75777cab_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "32", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "dd43de8f68764883b6e1fbab75777cab"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n32. Nhà nước cho thuê quyền sử dụng đất (sau đây gọi là Nhà nước cho thuê đất) là việc cơ quan nhà nước có thẩm quyền ban hành quyết định cho thuê đất cho đối tượng có nhu cầu sử dụng đất."}
{"Level_3_Foundations": [{"id": "d5d9aafd32da48c9a22f36cc091b640e_e1", "label": "LEGAL_CONCEPT", "name": "Nhà nước giao quyền sử dụng đất", "value": "Nhà nước giao quyền sử dụng đất (sau đây gọi là Nhà nước giao đất)"}, {"id": "d5d9aafd32da48c9a22f36cc091b640e_e2", "label": "DEFINITION", "name": "Định nghĩa Nhà nước giao đất", "value": "Nhà nước giao quyền sử dụng đất (sau đây gọi là Nhà nước giao đất) là việc cơ quan nhà nước có thẩm quyền ban hành quyết định giao đất cho đối tượng có nhu cầu sử dụng đất."}, {"id": "d5d9aafd32da48c9a22f36cc091b640e_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "d5d9aafd32da48c9a22f36cc091b640e_e4", "label": "SUBJECT", "name": "Đối tượng có nhu cầu sử dụng đất", "value": "đối tượng có nhu cầu sử dụng đất"}, {"id": "d5d9aafd32da48c9a22f36cc091b640e_e5", "label": "DOCUMENT_RECORD", "name": "Quyết định giao đất", "value": "quyết định giao đất"}], "Level_2_Rules_Actions": [{"id": "d5d9aafd32da48c9a22f36cc091b640e_e6", "label": "PROCEDURE_ACTION", "name": "Ban hành quyết định giao đất", "value": "ban hành quyết định giao đất cho đối tượng có nhu cầu sử dụng đất"}], "Attributes_Measures": [], "Relationships": [{"source": "d5d9aafd32da48c9a22f36cc091b640e_e1", "type": "DEFINES", "target": "d5d9aafd32da48c9a22f36cc091b640e_e2"}, {"source": "d5d9aafd32da48c9a22f36cc091b640e_e3", "type": "EXECUTES_ACTION", "target": "d5d9aafd32da48c9a22f36cc091b640e_e6"}, {"source": "d5d9aafd32da48c9a22f36cc091b640e_e6", "type": "REQUIRES_DOCUMENT", "target": "d5d9aafd32da48c9a22f36cc091b640e_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "34", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "d5d9aafd32da48c9a22f36cc091b640e"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n34. Nhà nước giao quyền sử dụng đất (sau đây gọi là Nhà nước giao đất) là việc cơ quan nhà nước có thẩm quyền ban hành quyết định giao đất cho đối tượng có nhu cầu sử dụng đất."}
{"Level_3_Foundations": [{"id": "de6701fd4ce6454382877cc14142b3a8_e1", "label": "LEGAL_CONCEPT", "name": "Nhà nước công nhận quyền sử dụng đất", "value": "Nhà nước công nhận quyền sử dụng đất"}, {"id": "de6701fd4ce6454382877cc14142b3a8_e2", "label": "DEFINITION", "name": "Định nghĩa về việc Nhà nước công nhận quyền sử dụng đất", "value": "Nhà nước công nhận quyền sử dụng đất là việc cơ quan nhà nước có thẩm quyền cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất lần đầu cho người đang sử dụng đất ổn định đối với thửa đất xác định theo quy định của Luật này."}, {"id": "de6701fd4ce6454382877cc14142b3a8_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "de6701fd4ce6454382877cc14142b3a8_e4", "label": "SUBJECT", "name": "Người đang sử dụng đất ổn định", "value": "người đang sử dụng đất ổn định"}, {"id": "de6701fd4ce6454382877cc14142b3a8_e5", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "de6701fd4ce6454382877cc14142b3a8_e6", "label": "OBJECT_EQUIPMENT", "name": "Thửa đất xác định", "value": "thửa đất xác định"}, {"id": "de6701fd4ce6454382877cc14142b3a8_e7", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định", "value": "sử dụng đất ổn định"}], "Level_2_Rules_Actions": [{"id": "de6701fd4ce6454382877cc14142b3a8_e8", "label": "PROCEDURE_ACTION", "name": "Cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất lần đầu", "value": "cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất lần đầu"}], "Attributes_Measures": [], "Relationships": [{"source": "de6701fd4ce6454382877cc14142b3a8_e1", "type": "DEFINES", "target": "de6701fd4ce6454382877cc14142b3a8_e2"}, {"source": "de6701fd4ce6454382877cc14142b3a8_e3", "type": "EXECUTES_ACTION", "target": "de6701fd4ce6454382877cc14142b3a8_e8"}, {"source": "de6701fd4ce6454382877cc14142b3a8_e8", "type": "REQUIRES_DOCUMENT", "target": "de6701fd4ce6454382877cc14142b3a8_e5"}, {"source": "de6701fd4ce6454382877cc14142b3a8_e8", "type": "APPLIES_TO_OBJECT", "target": "de6701fd4ce6454382877cc14142b3a8_e6"}, {"source": "de6701fd4ce6454382877cc14142b3a8_e4", "type": "MEETS_CONDITION", "target": "de6701fd4ce6454382877cc14142b3a8_e7"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "33", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "de6701fd4ce6454382877cc14142b3a8"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n33. Nhà nước công nhận quyền sử dụng đất là việc cơ quan nhà nước có thẩm quyền cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất lần đầu cho người đang sử dụng đất ổn định đối với thửa đất xác định theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "6635d17cee3b4b4ea75d2878d91faae5_e1", "label": "LEGAL_CONCEPT", "name": "Quy hoạch sử dụng đất", "value": "Quy hoạch sử dụng đất"}, {"id": "6635d17cee3b4b4ea75d2878d91faae5_e2", "label": "DEFINITION", "name": "Định nghĩa quy hoạch sử dụng đất", "value": "Quy hoạch sử dụng đất là việc phân bổ chỉ tiêu sử dụng đất và khoanh vùng đất đai cho các mục đích phát triển kinh tế - xã hội, quốc phòng, an ninh, bảo vệ môi trường và thích ứng với biến đổi khí hậu trên cơ sở tiềm năng đất đai và nhu cầu sử dụng đất của các ngành, lĩnh vực đối với từng đơn vị hành chính cho thời kỳ xác định."}, {"id": "6635d17cee3b4b4ea75d2878d91faae5_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "6635d17cee3b4b4ea75d2878d91faae5_e1", "type": "DEFINES", "target": "6635d17cee3b4b4ea75d2878d91faae5_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "36", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "6635d17cee3b4b4ea75d2878d91faae5"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n36. Quy hoạch sử dụng đất là việc phân bổ chỉ tiêu sử dụng đất và khoanh vùng đất đai cho các mục đích phát triển kinh tế - xã hội, quốc phòng, an ninh, bảo vệ môi trường và thích ứng với biến đổi khí hậu trên cơ sở tiềm năng đất đai và nhu cầu sử dụng đất của các ngành, lĩnh vực đối với từng đơn vị hành chính cho thời kỳ xác định."}
{"Level_3_Foundations": [{"id": "97a7c9ae14af4160ad075b2337493dc5_e1", "label": "LEGAL_CONCEPT", "name": "Nhà nước thu hồi đất", "value": "Nhà nước thu hồi đất"}, {"id": "97a7c9ae14af4160ad075b2337493dc5_e2", "label": "DEFINITION", "name": "Định nghĩa Nhà nước thu hồi đất", "value": "Nhà nước thu hồi đất là việc cơ quan nhà nước có thẩm quyền ban hành quyết định thu lại quyền sử dụng đất của người sử dụng đất hoặc thu lại đất của người đang sử dụng đất hoặc thu lại đất đang được Nhà nước giao quản lý."}, {"id": "97a7c9ae14af4160ad075b2337493dc5_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "97a7c9ae14af4160ad075b2337493dc5_e4", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "97a7c9ae14af4160ad075b2337493dc5_e5", "label": "SUBJECT", "name": "Người đang sử dụng đất", "value": "người đang sử dụng đất"}, {"id": "97a7c9ae14af4160ad075b2337493dc5_e6", "label": "DOCUMENT_RECORD", "name": "Điều 3, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "97a7c9ae14af4160ad075b2337493dc5_e1", "type": "DEFINES", "target": "97a7c9ae14af4160ad075b2337493dc5_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "35", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "97a7c9ae14af4160ad075b2337493dc5"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n35. Nhà nước thu hồi đất là việc cơ quan nhà nước có thẩm quyền ban hành quyết định thu lại quyền sử dụng đất của người sử dụng đất hoặc thu lại đất của người đang sử dụng đất hoặc thu lại đất đang được Nhà nước giao quản lý."}
{"Level_3_Foundations": [{"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e1", "label": "LEGAL_CONCEPT", "name": "Quyền thuê trong hợp đồng thuê đất", "value": "Quyền thuê trong hợp đồng thuê đất"}, {"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e2", "label": "DEFINITION", "name": "Định nghĩa Quyền thuê trong hợp đồng thuê đất", "value": "Quyền thuê trong hợp đồng thuê đất là quyền của người sử dụng đất được hình thành khi Nhà nước cho thuê đất thu tiền thuê đất hằng năm. Người sử dụng đất được chuyển nhượng quyền thuê trong hợp đồng thuê đất; người nhận chuyển nhượng quyền thuê trong hợp đồng thuê đất được kế thừa các quyền và nghĩa vụ của người sử dụng đất theo quy định của Luật này và quy định khác của pháp luật có liên quan."}, {"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e4", "label": "STANDARD_CONDITION", "name": "Nhà nước cho thuê đất thu tiền thuê đất hằng năm", "value": "khi Nhà nước cho thuê đất thu tiền thuê đất hằng năm"}, {"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e5", "label": "SUBJECT", "name": "Người nhận chuyển nhượng quyền thuê trong hợp đồng thuê đất", "value": "người nhận chuyển nhượng quyền thuê trong hợp đồng thuê đất"}], "Level_2_Rules_Actions": [{"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e6", "label": "RIGHT_OBLIGATION", "name": "Được chuyển nhượng quyền thuê trong hợp đồng thuê đất", "value": "Người sử dụng đất được chuyển nhượng quyền thuê trong hợp đồng thuê đất"}, {"id": "7c998ada0da54cc3a8e8d7f48b7b7a73_e7", "label": "RIGHT_OBLIGATION", "name": "Được kế thừa các quyền và nghĩa vụ của người sử dụng đất", "value": "người nhận chuyển nhượng quyền thuê trong hợp đồng thuê đất được kế thừa các quyền và nghĩa vụ của người sử dụng đất theo quy định của Luật này và quy định khác của pháp luật có liên quan"}], "Attributes_Measures": [], "Relationships": [{"source": "7c998ada0da54cc3a8e8d7f48b7b7a73_e1", "type": "DEFINES", "target": "7c998ada0da54cc3a8e8d7f48b7b7a73_e2"}, {"source": "7c998ada0da54cc3a8e8d7f48b7b7a73_e1", "type": "MEETS_CONDITION", "target": "7c998ada0da54cc3a8e8d7f48b7b7a73_e4"}, {"source": "7c998ada0da54cc3a8e8d7f48b7b7a73_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "7c998ada0da54cc3a8e8d7f48b7b7a73_e6"}, {"source": "7c998ada0da54cc3a8e8d7f48b7b7a73_e5", "type": "HAS_RIGHT_OBLIGATION", "target": "7c998ada0da54cc3a8e8d7f48b7b7a73_e7"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "37", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "7c998ada0da54cc3a8e8d7f48b7b7a73"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n37. Quyền thuê trong hợp đồng thuê đất là quyền của người sử dụng đất được hình thành khi Nhà nước cho thuê đất thu tiền thuê đất hằng năm. Người sử dụng đất được chuyển nhượng quyền thuê trong hợp đồng thuê đất; người nhận chuyển nhượng quyền thuê trong hợp đồng thuê đất được kế thừa các quyền và nghĩa vụ của người sử dụng đất theo quy định của Luật này và quy định khác của pháp luật có liên quan."}
{"Level_3_Foundations": [{"id": "13e9ff27cdb04eea810c55f4818e5333_e1", "label": "LEGAL_CONCEPT", "name": "Sử dụng đất ổn định", "value": "Sử dụng đất ổn định"}, {"id": "13e9ff27cdb04eea810c55f4818e5333_e2", "label": "DEFINITION", "name": "Định nghĩa sử dụng đất ổn định", "value": "Sử dụng đất ổn định là việc sử dụng đất vào một mục đích chính nhất định kể từ thời điểm bắt đầu sử dụng đất vào mục đích đó đến thời điểm cơ quan nhà nước có thẩm quyền xem xét việc sử dụng đất ổn định."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "13e9ff27cdb04eea810c55f4818e5333_e1", "type": "DEFINES", "target": "13e9ff27cdb04eea810c55f4818e5333_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "38", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "13e9ff27cdb04eea810c55f4818e5333"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n38. Sử dụng đất ổn định là việc sử dụng đất vào một mục đích chính nhất định kể từ thời điểm bắt đầu sử dụng đất vào mục đích đó đến thời điểm cơ quan nhà nước có thẩm quyền xem xét việc sử dụng đất ổn định."}
{"Level_3_Foundations": [{"id": "605fdeccb5e545ccbbbb8b4e65c13934_e1", "label": "LEGAL_CONCEPT", "name": "Thoái hóa đất", "value": "Thoái hóa đất"}, {"id": "605fdeccb5e545ccbbbb8b4e65c13934_e2", "label": "DEFINITION", "name": "Định nghĩa thoái hóa đất", "value": "Thoái hóa đất là tình trạng đất bị thay đổi đặc tính, tính chất vốn có ban đầu theo chiều hướng xấu do tác động của điều kiện tự nhiên, con người."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "605fdeccb5e545ccbbbb8b4e65c13934_e1", "type": "DEFINES", "target": "605fdeccb5e545ccbbbb8b4e65c13934_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "40", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "605fdeccb5e545ccbbbb8b4e65c13934"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n40. Thoái hóa đất là tình trạng đất bị thay đổi đặc tính, tính chất vốn có ban đầu theo chiều hướng xấu do tác động của điều kiện tự nhiên, con người."}
{"Level_3_Foundations": [{"id": "29ccb40eaea04b0492c5bdf3868b6178_e1", "label": "LEGAL_CONCEPT", "name": "Tái định cư", "value": "Tái định cư"}, {"id": "29ccb40eaea04b0492c5bdf3868b6178_e2", "label": "DEFINITION", "name": "Định nghĩa Tái định cư", "value": "Tái định cư là việc Nhà nước thực hiện bồi thường bằng đất ở hoặc bằng nhà ở tại khu tái định cư hoặc địa điểm khác phù hợp cho người có đất thu hồi hoặc hỗ trợ bằng giao đất ở, nhà ở tái định cư cho người không đủ điều kiện bồi thường về đất ở theo quy định của Luật này nhưng không còn chỗ ở nào khác."}, {"id": "29ccb40eaea04b0492c5bdf3868b6178_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "29ccb40eaea04b0492c5bdf3868b6178_e4", "label": "SUBJECT", "name": "Người có đất thu hồi hoặc người không đủ điều kiện bồi thường về đất ở", "value": "người có đất thu hồi hoặc người không đủ điều kiện bồi thường về đất ở theo quy định của Luật này nhưng không còn chỗ ở nào khác"}], "Level_2_Rules_Actions": [{"id": "29ccb40eaea04b0492c5bdf3868b6178_e5", "label": "PROCEDURE_ACTION", "name": "Bồi thường hoặc hỗ trợ tái định cư", "value": "thực hiện bồi thường bằng đất ở hoặc bằng nhà ở tại khu tái định cư hoặc địa điểm khác phù hợp cho người có đất thu hồi hoặc hỗ trợ bằng giao đất ở, nhà ở tái định cư cho người không đủ điều kiện bồi thường về đất ở theo quy định của Luật này nhưng không còn chỗ ở nào khác"}], "Attributes_Measures": [], "Relationships": [{"source": "29ccb40eaea04b0492c5bdf3868b6178_e1", "type": "DEFINES", "target": "29ccb40eaea04b0492c5bdf3868b6178_e2"}, {"source": "29ccb40eaea04b0492c5bdf3868b6178_e3", "type": "EXECUTES_ACTION", "target": "29ccb40eaea04b0492c5bdf3868b6178_e5"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "39", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "29ccb40eaea04b0492c5bdf3868b6178"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n39. Tái định cư là việc Nhà nước thực hiện bồi thường bằng đất ở hoặc bằng nhà ở tại khu tái định cư hoặc địa điểm khác phù hợp cho người có đất thu hồi hoặc hỗ trợ bằng giao đất ở, nhà ở tái định cư cho người không đủ điều kiện bồi thường về đất ở theo quy định của Luật này nhưng không còn chỗ ở nào khác."}
{"Level_3_Foundations": [{"id": "16df30f11210470da2be79e709998bfe_e1", "label": "LEGAL_CONCEPT", "name": "Thống kê đất đai", "value": "Thống kê đất đai"}, {"id": "16df30f11210470da2be79e709998bfe_e2", "label": "DEFINITION", "name": "Định nghĩa Thống kê đất đai", "value": "Thống kê đất đai là việc Nhà nước tổng hợp, đánh giá trên hồ sơ địa chính về hiện trạng sử dụng đất tại thời điểm thống kê và biến động đất đai giữa 02 lần thống kê."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "16df30f11210470da2be79e709998bfe_e1", "type": "DEFINES", "target": "16df30f11210470da2be79e709998bfe_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "41", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "16df30f11210470da2be79e709998bfe"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n41. Thống kê đất đai là việc Nhà nước tổng hợp, đánh giá trên hồ sơ địa chính về hiện trạng sử dụng đất tại thời điểm thống kê và biến động đất đai giữa 02 lần thống kê."}
{"Level_3_Foundations": [{"id": "eb38bd558fdf48698e76c0e8619cf5f0_e1", "label": "LEGAL_CONCEPT", "name": "Thửa đất", "value": "Thửa đất"}, {"id": "eb38bd558fdf48698e76c0e8619cf5f0_e2", "label": "DEFINITION", "name": "Định nghĩa thửa đất", "value": "Thửa đất là phần diện tích đất được giới hạn bởi ranh giới mô tả trên hồ sơ địa chính hoặc được xác định trên thực địa."}, {"id": "eb38bd558fdf48698e76c0e8619cf5f0_e3", "label": "DOCUMENT_RECORD", "name": "Hồ sơ địa chính", "value": "hồ sơ địa chính"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "eb38bd558fdf48698e76c0e8619cf5f0_e1", "type": "DEFINES", "target": "eb38bd558fdf48698e76c0e8619cf5f0_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "42", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "eb38bd558fdf48698e76c0e8619cf5f0"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n42. Thửa đất là phần diện tích đất được giới hạn bởi ranh giới mô tả trên hồ sơ địa chính hoặc được xác định trên thực địa."}
{"Level_3_Foundations": [{"id": "d14cd93f523d4b4fbd2c0d427297575b_e1", "label": "LEGAL_CONCEPT", "name": "Thửa đất chuẩn", "value": "Thửa đất chuẩn"}, {"id": "d14cd93f523d4b4fbd2c0d427297575b_e2", "label": "DEFINITION", "name": "Định nghĩa thửa đất chuẩn", "value": "Thửa đất chuẩn là thửa đất có các đặc tính về diện tích, hình thể, kích thước mang tính đại diện cho các thửa đất trong vùng giá trị, được chọn làm thửa đất chuẩn để định giá cho các thửa đất khác trong vùng giá trị."}, {"id": "d14cd93f523d4b4fbd2c0d427297575b_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 43, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n43. Thửa đất chuẩn là thửa đất có các đặc tính về diện tích, hình thể, kích thước mang tính đại diện cho các thửa đất trong vùng giá trị, được chọn làm thửa đất chuẩn để định giá cho các thửa đất khác trong vùng giá trị."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "d14cd93f523d4b4fbd2c0d427297575b_e1", "type": "DEFINES", "target": "d14cd93f523d4b4fbd2c0d427297575b_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "43", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "d14cd93f523d4b4fbd2c0d427297575b"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n43. Thửa đất chuẩn là thửa đất có các đặc tính về diện tích, hình thể, kích thước mang tính đại diện cho các thửa đất trong vùng giá trị, được chọn làm thửa đất chuẩn để định giá cho các thửa đất khác trong vùng giá trị."}
{"Level_3_Foundations": [{"id": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e1", "label": "LEGAL_CONCEPT", "name": "Tiền thuê đất", "value": "Tiền thuê đất"}, {"id": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e2", "label": "DEFINITION", "name": "Định nghĩa Tiền thuê đất", "value": "Tiền thuê đất là số tiền mà người sử dụng đất phải trả cho Nhà nước khi được Nhà nước cho thuê đất, cho phép chuyển mục đích sử dụng đất để cho thuê đất hoặc các trường hợp sử dụng đất mà phải nộp tiền thuê đất theo quy định của pháp luật."}, {"id": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e1", "type": "DEFINES", "target": "8b29bae8e85642e0b0dd0b12d0e1dcb7_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "45", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "8b29bae8e85642e0b0dd0b12d0e1dcb7"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n45. Tiền thuê đất là số tiền mà người sử dụng đất phải trả cho Nhà nước khi được Nhà nước cho thuê đất, cho phép chuyển mục đích sử dụng đất để cho thuê đất hoặc các trường hợp sử dụng đất mà phải nộp tiền thuê đất theo quy định của pháp luật."}
{"Level_3_Foundations": [{"id": "a57c8bd6333e48569b3a5c12b8ee0875_e1", "label": "LEGAL_CONCEPT", "name": "Tiền sử dụng đất", "value": "Tiền sử dụng đất"}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e2", "label": "DEFINITION", "name": "Định nghĩa Tiền sử dụng đất", "value": "Tiền sử dụng đất là số tiền mà người sử dụng đất phải trả cho Nhà nước khi được Nhà nước giao đất có thu tiền sử dụng đất, cho phép chuyển mục đích sử dụng đất hoặc các trường hợp sử dụng đất mà phải nộp tiền sử dụng đất theo quy định của pháp luật."}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e5", "label": "STANDARD_CONDITION", "name": "Được Nhà nước giao đất có thu tiền sử dụng đất", "value": "được Nhà nước giao đất có thu tiền sử dụng đất"}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e6", "label": "STANDARD_CONDITION", "name": "Được cho phép chuyển mục đích sử dụng đất", "value": "cho phép chuyển mục đích sử dụng đất"}, {"id": "a57c8bd6333e48569b3a5c12b8ee0875_e7", "label": "STANDARD_CONDITION", "name": "Các trường hợp sử dụng đất phải nộp tiền sử dụng đất theo quy định", "value": "các trường hợp sử dụng đất mà phải nộp tiền sử dụng đất theo quy định của pháp luật"}], "Level_2_Rules_Actions": [{"id": "a57c8bd6333e48569b3a5c12b8ee0875_e8", "label": "RIGHT_OBLIGATION", "name": "Phải trả tiền sử dụng đất cho Nhà nước", "value": "phải trả cho Nhà nước khi được Nhà nước giao đất có thu tiền sử dụng đất, cho phép chuyển mục đích sử dụng đất hoặc các trường hợp sử dụng đất mà phải nộp tiền sử dụng đất theo quy định của pháp luật"}], "Attributes_Measures": [], "Relationships": [{"source": "a57c8bd6333e48569b3a5c12b8ee0875_e1", "type": "DEFINES", "target": "a57c8bd6333e48569b3a5c12b8ee0875_e2"}, {"source": "a57c8bd6333e48569b3a5c12b8ee0875_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "a57c8bd6333e48569b3a5c12b8ee0875_e8"}, {"source": "a57c8bd6333e48569b3a5c12b8ee0875_e8", "type": "MEETS_CONDITION", "target": "a57c8bd6333e48569b3a5c12b8ee0875_e5"}, {"source": "a57c8bd6333e48569b3a5c12b8ee0875_e8", "type": "MEETS_CONDITION", "target": "a57c8bd6333e48569b3a5c12b8ee0875_e6"}, {"source": "a57c8bd6333e48569b3a5c12b8ee0875_e8", "type": "MEETS_CONDITION", "target": "a57c8bd6333e48569b3a5c12b8ee0875_e7"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "44", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a57c8bd6333e48569b3a5c12b8ee0875"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n44. Tiền sử dụng đất là số tiền mà người sử dụng đất phải trả cho Nhà nước khi được Nhà nước giao đất có thu tiền sử dụng đất, cho phép chuyển mục đích sử dụng đất hoặc các trường hợp sử dụng đất mà phải nộp tiền sử dụng đất theo quy định của pháp luật."}
{"Level_3_Foundations": [{"id": "de95da6b192d48369ccbbd61ebe1b8ed_e1", "label": "LEGAL_CONCEPT", "name": "Tổ chức kinh tế có vốn đầu tư nước ngoài", "value": "Tổ chức kinh tế có vốn đầu tư nước ngoài"}, {"id": "de95da6b192d48369ccbbd61ebe1b8ed_e2", "label": "DEFINITION", "name": "Định nghĩa Tổ chức kinh tế có vốn đầu tư nước ngoài", "value": "Tổ chức kinh tế có vốn đầu tư nước ngoài là tổ chức kinh tế phải đáp ứng điều kiện và thực hiện thủ tục đầu tư quy định đối với nhà đầu tư nước ngoài theo quy định của Luật Đầu tư để thực hiện dự án có sử dụng đất."}, {"id": "de95da6b192d48369ccbbd61ebe1b8ed_e3", "label": "STANDARD_CONDITION", "name": "Đáp ứng điều kiện và thực hiện thủ tục đầu tư như nhà đầu tư nước ngoài", "value": "phải đáp ứng điều kiện và thực hiện thủ tục đầu tư quy định đối với nhà đầu tư nước ngoài theo quy định của Luật Đầu tư để thực hiện dự án có sử dụng đất."}, {"id": "de95da6b192d48369ccbbd61ebe1b8ed_e4", "label": "SUBJECT", "name": "Nhà đầu tư nước ngoài", "value": "nhà đầu tư nước ngoài"}, {"id": "de95da6b192d48369ccbbd61ebe1b8ed_e5", "label": "DOCUMENT_RECORD", "name": "Luật Đầu tư", "value": "Luật Đầu tư"}, {"id": "de95da6b192d48369ccbbd61ebe1b8ed_e6", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "tổ chức kinh tế"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "de95da6b192d48369ccbbd61ebe1b8ed_e1", "type": "DEFINES", "target": "de95da6b192d48369ccbbd61ebe1b8ed_e2"}, {"source": "de95da6b192d48369ccbbd61ebe1b8ed_e1", "type": "MEETS_CONDITION", "target": "de95da6b192d48369ccbbd61ebe1b8ed_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "46", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "de95da6b192d48369ccbbd61ebe1b8ed"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n46. Tổ chức kinh tế có vốn đầu tư nước ngoài là tổ chức kinh tế phải đáp ứng điều kiện và thực hiện thủ tục đầu tư quy định đối với nhà đầu tư nước ngoài theo quy định của Luật Đầu tư để thực hiện dự án có sử dụng đất."}
{"Level_3_Foundations": [{"id": "9c3e4d562c2c44909f6c59e6cc296d17_e1", "label": "LEGAL_CONCEPT", "name": "Tranh chấp đất đai", "value": "Tranh chấp đất đai"}, {"id": "9c3e4d562c2c44909f6c59e6cc296d17_e2", "label": "DEFINITION", "name": "Định nghĩa tranh chấp đất đai", "value": "Tranh chấp đất đai là tranh chấp về quyền, nghĩa vụ của người sử dụng đất giữa hai hoặc nhiều bên trong quan hệ đất đai."}, {"id": "9c3e4d562c2c44909f6c59e6cc296d17_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "9c3e4d562c2c44909f6c59e6cc296d17_e4", "label": "DOCUMENT_RECORD", "name": "Điều 3, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "9c3e4d562c2c44909f6c59e6cc296d17_e1", "type": "DEFINES", "target": "9c3e4d562c2c44909f6c59e6cc296d17_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "47", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9c3e4d562c2c44909f6c59e6cc296d17"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n47. Tranh chấp đất đai là tranh chấp về quyền, nghĩa vụ của người sử dụng đất giữa hai hoặc nhiều bên trong quan hệ đất đai."}
{"Level_3_Foundations": [{"id": "05b1ba2010114b098847c2ed12aac152_e1", "label": "LEGAL_CONCEPT", "name": "Vùng phụ cận", "value": "Vùng phụ cận"}, {"id": "05b1ba2010114b098847c2ed12aac152_e2", "label": "DEFINITION", "name": "Định nghĩa Vùng phụ cận", "value": "Vùng phụ cận là vùng đất tiếp giáp với các điểm kết nối giao thông và các tuyến giao thông có tiềm năng phát triển theo quy hoạch."}, {"id": "05b1ba2010114b098847c2ed12aac152_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, 179ce9fe1bec4563b32cfe4582590806", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "05b1ba2010114b098847c2ed12aac152_e1", "type": "DEFINES", "target": "05b1ba2010114b098847c2ed12aac152_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "49", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "05b1ba2010114b098847c2ed12aac152"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n49. Vùng phụ cận là vùng đất tiếp giáp với các điểm kết nối giao thông và các tuyến giao thông có tiềm năng phát triển theo quy hoạch."}
{"Level_3_Foundations": [{"id": "fdeacdf4f3bf4d48a9e1bf9be037e620_e1", "label": "LEGAL_CONCEPT", "name": "Vùng giá trị", "value": "Vùng giá trị"}, {"id": "fdeacdf4f3bf4d48a9e1bf9be037e620_e2", "label": "DEFINITION", "name": "Định nghĩa Vùng giá trị", "value": "Vùng giá trị là khu vực các thửa đất liền kề nhau, có cùng mục đích sử dụng và có các yếu tố tương đồng về vị trí, khả năng sinh lợi, điều kiện kết cấu hạ tầng và yếu tố khác ảnh hưởng đến giá đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "fdeacdf4f3bf4d48a9e1bf9be037e620_e1", "type": "DEFINES", "target": "fdeacdf4f3bf4d48a9e1bf9be037e620_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "48", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "fdeacdf4f3bf4d48a9e1bf9be037e620"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n48. Vùng giá trị là khu vực các thửa đất liền kề nhau, có cùng mục đích sử dụng và có các yếu tố tương đồng về vị trí, khả năng sinh lợi, điều kiện kết cấu hạ tầng và yếu tố khác ảnh hưởng đến giá đất."}
{"Level_3_Foundations": [{"id": "5d94380a64954865a2720f4304f65502_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "5d94380a64954865a2720f4304f65502_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này"}, {"id": "5d94380a64954865a2720f4304f65502_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "5d94380a64954865a2720f4304f65502_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "5d94380a64954865a2720f4304f65502_e5", "label": "SUBJECT", "name": "Tổ chức tôn giáo, tổ chức tôn giáo trực thuộc", "value": "Tổ chức tôn giáo, tổ chức tôn giáo trực thuộc"}, {"id": "5d94380a64954865a2720f4304f65502_e6", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận"}, {"id": "5d94380a64954865a2720f4304f65502_e7", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận liên quan đến quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sử dụng đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}], "Level_2_Rules_Actions": [{"id": "5d94380a64954865a2720f4304f65502_e8", "label": "PROCEDURE_ACTION", "name": "Giao đất, cho thuê đất, công nhận quyền sử dụng đất", "value": "giao đất, cho thuê đất, công nhận quyền sử dụng đất"}, {"id": "5d94380a64954865a2720f4304f65502_e9", "label": "PROCEDURE_ACTION", "name": "Nhận quyền sử dụng đất", "value": "nhận quyền sử dụng đất"}, {"id": "5d94380a64954865a2720f4304f65502_e10", "label": "PROCEDURE_ACTION", "name": "Thuê lại đất", "value": "thuê lại đất"}], "Attributes_Measures": [], "Relationships": [{"source": "5d94380a64954865a2720f4304f65502_e1", "type": "DEFINES", "target": "5d94380a64954865a2720f4304f65502_e2"}, {"source": "5d94380a64954865a2720f4304f65502_e4", "type": "EXECUTES_ACTION", "target": "5d94380a64954865a2720f4304f65502_e8"}, {"source": "5d94380a64954865a2720f4304f65502_e3", "type": "MEETS_CONDITION", "target": "5d94380a64954865a2720f4304f65502_e6"}, {"source": "5d94380a64954865a2720f4304f65502_e6", "type": "REQUIRES_DOCUMENT", "target": "5d94380a64954865a2720f4304f65502_e7"}, {"source": "5d94380a64954865a2720f4304f65502_e3", "type": "EXECUTES_ACTION", "target": "5d94380a64954865a2720f4304f65502_e9"}, {"source": "5d94380a64954865a2720f4304f65502_e3", "type": "EXECUTES_ACTION", "target": "5d94380a64954865a2720f4304f65502_e10"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5d94380a64954865a2720f4304f65502"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n2. Tổ chức tôn giáo, tổ chức tôn giáo trực thuộc;"}
{"Level_3_Foundations": [{"id": "0cae383bb60343d6aeca39bf88357a82_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "0cae383bb60343d6aeca39bf88357a82_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "0cae383bb60343d6aeca39bf88357a82_e3", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "0cae383bb60343d6aeca39bf88357a82_e4", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "Tổ chức kinh tế theo quy định của Luật Đầu tư, trừ trường hợp quy định tại khoản 7 Điều này (sau đây gọi là tổ chức kinh tế)"}, {"id": "0cae383bb60343d6aeca39bf88357a82_e5", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận liên quan đến quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}, {"id": "0cae383bb60343d6aeca39bf88357a82_e6", "label": "DOCUMENT_RECORD", "name": "Luật Đầu tư", "value": "Luật Đầu tư"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "0cae383bb60343d6aeca39bf88357a82_e1", "type": "DEFINES", "target": "0cae383bb60343d6aeca39bf88357a82_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "1", "diem": "b", "type": "LEGAL_RULE", "chunk_uuid": "0cae383bb60343d6aeca39bf88357a82"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n1. Tổ chức trong nước gồm:\nb) Tổ chức kinh tế theo quy định của Luật Đầu tư, trừ trường hợp quy định tại khoản 7 Điều này (sau đây gọi là tổ chức kinh tế);"}
{"Level_3_Foundations": [{"id": "c02001014ebe40a0809eb162bc157008_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này"}, {"id": "c02001014ebe40a0809eb162bc157008_e2", "label": "SUBJECT", "name": "Tổ chức trong nước là người sử dụng đất", "value": "Tổ chức trong nước gồm: a) Cơ quan nhà nước, cơ quan Đảng Cộng sản Việt Nam, đơn vị vũ trang nhân dân, Mặt trận Tổ quốc Việt Nam, tổ chức chính trị - xã hội, tổ chức chính trị xã hội - nghề nghiệp, tổ chức xã hội, tổ chức xã hội - nghề nghiệp, đơn vị sự nghiệp công lập và tổ chức khác theo quy định của pháp luật"}, {"id": "c02001014ebe40a0809eb162bc157008_e3", "label": "STANDARD_CONDITION", "name": "Điều kiện để là người sử dụng đất", "value": "được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất"}, {"id": "c02001014ebe40a0809eb162bc157008_e4", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận liên quan đến quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "c02001014ebe40a0809eb162bc157008_e1", "type": "MEETS_CONDITION", "target": "c02001014ebe40a0809eb162bc157008_e3"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "1", "diem": "a", "type": "LEGAL_RULE", "chunk_uuid": "c02001014ebe40a0809eb162bc157008"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n1. Tổ chức trong nước gồm:\na) Cơ quan nhà nước, cơ quan Đảng Cộng sản Việt Nam, đơn vị vũ trang nhân dân, Mặt trận Tổ quốc Việt Nam, tổ chức chính trị - xã hội, tổ chức chính trị xã hội - nghề nghiệp, tổ chức xã hội, tổ chức xã hội - nghề nghiệp, đơn vị sự nghiệp công lập và tổ chức khác theo quy định của pháp luật;"}
{"Level_3_Foundations": [{"id": "e83cd4ad74bf49d2a26100373ed9d4fb_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "e83cd4ad74bf49d2a26100373ed9d4fb_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "e83cd4ad74bf49d2a26100373ed9d4fb_e3", "label": "SUBJECT", "name": "Tổ chức nước ngoài có chức năng ngoại giao", "value": "Tổ chức nước ngoài có chức năng ngoại giao gồm cơ quan đại diện ngoại giao, cơ quan lãnh sự, cơ quan đại diện khác của nước ngoài có chức năng ngoại giao được Chính phủ Việt Nam thừa nhận; cơ quan đại diện của tổ chức thuộc Liên hợp quốc, cơ quan hoặc tổ chức liên chính phủ, cơ quan đại diện của tổ chức liên chính phủ."}, {"id": "e83cd4ad74bf49d2a26100373ed9d4fb_e4", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận liên quan đến quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sử dụng đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e83cd4ad74bf49d2a26100373ed9d4fb_e1", "type": "DEFINES", "target": "e83cd4ad74bf49d2a26100373ed9d4fb_e2"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e83cd4ad74bf49d2a26100373ed9d4fb"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n5. Tổ chức nước ngoài có chức năng ngoại giao gồm cơ quan đại diện ngoại giao, cơ quan lãnh sự, cơ quan đại diện khác của nước ngoài có chức năng ngoại giao được Chính phủ Việt Nam thừa nhận; cơ quan đại diện của tổ chức thuộc Liên hợp quốc, cơ quan hoặc tổ chức liên chính phủ, cơ quan đại diện của tổ chức liên chính phủ;"}
{"Level_3_Foundations": [{"id": "063b86052b164971947021e5b083c241_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "063b86052b164971947021e5b083c241_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "063b86052b164971947021e5b083c241_e3", "label": "SUBJECT", "name": "Cá nhân", "value": "Cá nhân trong nước, người Việt Nam định cư ở nước ngoài là công dân Việt Nam (sau đây gọi là cá nhân)"}, {"id": "063b86052b164971947021e5b083c241_e4", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "063b86052b164971947021e5b083c241_e5", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "063b86052b164971947021e5b083c241_e6", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất"}, {"id": "063b86052b164971947021e5b083c241_e7", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở", "value": "Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở"}, {"id": "063b86052b164971947021e5b083c241_e8", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}], "Level_2_Rules_Actions": [{"id": "063b86052b164971947021e5b083c241_e9", "label": "RIGHT_OBLIGATION", "name": "Được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất", "value": "được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất"}, {"id": "063b86052b164971947021e5b083c241_e10", "label": "RIGHT_OBLIGATION", "name": "Nhận quyền sử dụng đất", "value": "nhận quyền sử dụng đất"}, {"id": "063b86052b164971947021e5b083c241_e11", "label": "RIGHT_OBLIGATION", "name": "Thuê lại đất", "value": "thuê lại đất theo quy định của Luật này"}], "Attributes_Measures": [], "Relationships": [{"source": "063b86052b164971947021e5b083c241_e1", "type": "DEFINES", "target": "063b86052b164971947021e5b083c241_e2"}, {"source": "063b86052b164971947021e5b083c241_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "063b86052b164971947021e5b083c241_e9"}, {"source": "063b86052b164971947021e5b083c241_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "063b86052b164971947021e5b083c241_e10"}, {"source": "063b86052b164971947021e5b083c241_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "063b86052b164971947021e5b083c241_e11"}, {"source": "063b86052b164971947021e5b083c241_e3", "type": "MEETS_CONDITION", "target": "063b86052b164971947021e5b083c241_e4"}], "metadata": {"document": "179ce9fe1bec4563b32cfe4582590806", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "063b86052b164971947021e5b083c241"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n3. Cá nhân trong nước, người Việt Nam định cư ở nước ngoài là công dân Việt Nam (sau đây gọi là cá nhân);"}
{"Level_3_Foundations": [{"id": "7a45d1b129e648e0952df030a9d0f645_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "7a45d1b129e648e0952df030a9d0f645_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này"}, {"id": "7a45d1b129e648e0952df030a9d0f645_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "7a45d1b129e648e0952df030a9d0f645_e4", "label": "SUBJECT", "name": "Cộng đồng dân cư", "value": "Cộng đồng dân cư"}, {"id": "7a45d1b129e648e0952df030a9d0f645_e5", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận"}, {"id": "7a45d1b129e648e0952df030a9d0f645_e6", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận về quyền sử dụng đất và sở hữu tài sản", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}], "Level_2_Rules_Actions": [{"id": "7a45d1b129e648e0952df030a9d0f645_e7", "label": "RIGHT_OBLIGATION", "name": "Được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng 