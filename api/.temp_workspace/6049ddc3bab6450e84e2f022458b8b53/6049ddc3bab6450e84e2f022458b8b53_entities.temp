ất theo quy định của Luật này", "value": "thuê lại đất theo quy định của Luật này"}, {"id": "581e6454da9140018d9f485e890656b1_e8", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất"}, {"id": "581e6454da9140018d9f485e890656b1_e9", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở", "value": "Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở"}, {"id": "581e6454da9140018d9f485e890656b1_e10", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}, {"id": "581e6454da9140018d9f485e890656b1_e11", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "581e6454da9140018d9f485e890656b1_e12", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "581e6454da9140018d9f485e890656b1_e13", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "Tổ chức kinh tế theo quy định của Luật Đầu tư, trừ trường hợp quy định tại khoản 7 Điều này (sau đây gọi là tổ chức kinh tế)"}, {"id": "581e6454da9140018d9f485e890656b1_e14", "label": "DOCUMENT_RECORD", "name": "Luật Đầu tư", "value": "Luật Đầu tư"}], "Level_2_Rules_Actions": [{"id": "581e6454da9140018d9f485e890656b1_e15", "label": "PROHIBITED_EXCLUDED", "name": "Trường hợp loại trừ theo khoản 7 Điều này", "value": "trừ trường hợp quy định tại khoản 7 Điều này"}], "Attributes_Measures": [], "Relationships": [{"source": "581e6454da9140018d9f485e890656b1_e2", "type": "DEFINES", "target": "581e6454da9140018d9f485e890656b1_e3"}, {"source": "581e6454da9140018d9f485e890656b1_e1", "type": "MEETS_CONDITION", "target": "581e6454da9140018d9f485e890656b1_e4"}, {"source": "581e6454da9140018d9f485e890656b1_e1", "type": "MEETS_CONDITION", "target": "581e6454da9140018d9f485e890656b1_e5"}, {"source": "581e6454da9140018d9f485e890656b1_e1", "type": "MEETS_CONDITION", "target": "581e6454da9140018d9f485e890656b1_e6"}, {"source": "581e6454da9140018d9f485e890656b1_e1", "type": "MEETS_CONDITION", "target": "581e6454da9140018d9f485e890656b1_e7"}, {"source": "581e6454da9140018d9f485e890656b1_e13", "type": "IS_PROHIBITED_OR_EXCLUDED", "target": "581e6454da9140018d9f485e890656b1_e15"}], "metadata": {"document": "6049ddc3bab6450e84e2f022458b8b53", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "1", "diem": "b", "type": "LEGAL_RULE", "chunk_uuid": "581e6454da9140018d9f485e890656b1"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n1. Tổ chức trong nước gồm:\nb) Tổ chức kinh tế theo quy định của Luật Đầu tư, trừ trường hợp quy định tại khoản 7 Điều này (sau đây gọi là tổ chức kinh tế);"}
{"Level_3_Foundations": [{"id": "06764f1bce0144e79583a38f0d550e7b_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "06764f1bce0144e79583a38f0d550e7b_e2", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e3", "label": "SUBJECT", "name": "Tổ chức trong nước", "value": "Tổ chức trong nước"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e4", "label": "SUBJECT", "name": "Các tổ chức trong nước là người sử dụng đất", "value": "Cơ quan nhà nước, cơ quan Đảng Cộng sản Việt Nam, đơn vị vũ trang nhân dân, Mặt trận Tổ quốc Việt Nam, tổ chức chính trị - xã hội, tổ chức chính trị xã hội - nghề nghiệp, tổ chức xã hội, tổ chức xã hội - nghề nghiệp, đơn vị sự nghiệp công lập và tổ chức khác theo quy định của pháp luật"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e5", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận về quyền sử dụng đất và sở hữu tài sản", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sử dụng đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e6", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định", "value": "đang sử dụng đất ổn định"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e7", "label": "STANDARD_CONDITION", "name": "Đủ điều kiện cấp Giấy chứng nhận", "value": "đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}], "Level_2_Rules_Actions": [{"id": "06764f1bce0144e79583a38f0d550e7b_e8", "label": "PROCEDURE_ACTION", "name": "Giao đất, cho thuê đất, công nhận quyền sử dụng đất", "value": "giao đất, cho thuê đất, công nhận quyền sử dụng đất"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e9", "label": "PROCEDURE_ACTION", "name": "Nhận quyền sử dụng đất", "value": "nhận quyền sử dụng đất"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e10", "label": "PROCEDURE_ACTION", "name": "Thuê lại đất", "value": "thuê lại đất theo quy định của Luật này"}, {"id": "06764f1bce0144e79583a38f0d550e7b_e11", "label": "PROCEDURE_ACTION", "name": "Cấp Giấy chứng nhận", "value": "cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}], "Attributes_Measures": [], "Relationships": [{"source": "06764f1bce0144e79583a38f0d550e7b_e2", "type": "EXECUTES_ACTION", "target": "06764f1bce0144e79583a38f0d550e7b_e8"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e1", "type": "EXECUTES_ACTION", "target": "06764f1bce0144e79583a38f0d550e7b_e9"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e1", "type": "EXECUTES_ACTION", "target": "06764f1bce0144e79583a38f0d550e7b_e10"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e1", "type": "MEETS_CONDITION", "target": "06764f1bce0144e79583a38f0d550e7b_e6"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e1", "type": "MEETS_CONDITION", "target": "06764f1bce0144e79583a38f0d550e7b_e7"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e2", "type": "EXECUTES_ACTION", "target": "06764f1bce0144e79583a38f0d550e7b_e11"}, {"source": "06764f1bce0144e79583a38f0d550e7b_e11", "type": "REQUIRES_DOCUMENT", "target": "06764f1bce0144e79583a38f0d550e7b_e5"}], "metadata": {"document": "6049ddc3bab6450e84e2f022458b8b53", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "1", "diem": "a", "type": "LEGAL_RULE", "chunk_uuid": "06764f1bce0144e79583a38f0d550e7b"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n1. Tổ chức trong nước gồm:\na) Cơ quan nhà nước, cơ quan Đảng Cộng sản Việt Nam, đơn vị vũ trang nhân dân, Mặt trận Tổ quốc Việt Nam, tổ chức chính trị - xã hội, tổ chức chính trị xã hội - nghề nghiệp, tổ chức xã hội, tổ chức xã hội - nghề nghiệp, đơn vị sự nghiệp công lập và tổ chức khác theo quy định của pháp luật;"}
{"Level_3_Foundations": [{"id": "456d556bd7ac4eeea7c9c4816c3cd56c_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "456d556bd7ac4eeea7c9c4816c3cd56c_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "456d556bd7ac4eeea7c9c4816c3cd56c_e3", "label": "SUBJECT", "name": "Tổ chức nước ngoài có chức năng ngoại giao", "value": "Tổ chức nước ngoài có chức năng ngoại giao gồm cơ quan đại diện ngoại giao, cơ quan lãnh sự, cơ quan đại diện khác của nước ngoài có chức năng ngoại giao được Chính phủ Việt Nam thừa nhận; cơ quan đại diện của tổ chức thuộc Liên hợp quốc, cơ quan hoặc tổ chức liên chính phủ, cơ quan đại diện của tổ chức liên chính phủ."}, {"id": "456d556bd7ac4eeea7c9c4816c3cd56c_e4", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "456d556bd7ac4eeea7c9c4816c3cd56c_e5", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận về quyền sử dụng đất và sở hữu tài sản", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sử dụng đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "456d556bd7ac4eeea7c9c4816c3cd56c_e1", "type": "DEFINES", "target": "456d556bd7ac4eeea7c9c4816c3cd56c_e2"}, {"source": "456d556bd7ac4eeea7c9c4816c3cd56c_e1", "type": "MEETS_CONDITION", "target": "456d556bd7ac4eeea7c9c4816c3cd56c_e4"}], "metadata": {"document": "6049ddc3bab6450e84e2f022458b8b53", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "456d556bd7ac4eeea7c9c4816c3cd56c"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n5. Tổ chức nước ngoài có chức năng ngoại giao gồm cơ quan đại diện ngoại giao, cơ quan lãnh sự, cơ quan đại diện khác của nước ngoài có chức năng ngoại giao được Chính phủ Việt Nam thừa nhận; cơ quan đại diện của tổ chức thuộc Liên hợp quốc, cơ quan hoặc tổ chức liên chính phủ, cơ quan đại diện của tổ chức liên chính phủ;"}
{"Level_3_Foundations": [{"id": "53f044078d0c40248bcbd40df78c39fa_e1", "label": "LEGAL_CONCEPT", "name": "Người sử dụng đất", "value": "Người sử dụng đất"}, {"id": "53f044078d0c40248bcbd40df78c39fa_e2", "label": "DEFINITION", "name": "Định nghĩa Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này."}, {"id": "53f044078d0c40248bcbd40df78c39fa_e3", "label": "SUBJECT", "name": "Cá nhân", "value": "Cá nhân trong nước, người Việt Nam định cư ở nước ngoài là công dân Việt Nam (sau đây gọi là cá nhân)."}, {"id": "53f044078d0c40248bcbd40df78c39fa_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "53f044078d0c40248bcbd40df78c39fa_e5", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận về quyền sử dụng đất và sở hữu tài sản", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất."}, {"id": "53f044078d0c40248bcbd40df78c39fa_e6", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận nhưng chưa được cấp", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận."}], "Level_2_Rules_Actions": [{"id": "53f044078d0c40248bcbd40df78c39fa_e7", "label": "PROCEDURE_ACTION", "name": "Giao đất, cho thuê đất, công nhận quyền sử dụng đất", "value": "giao đất, cho thuê đất, công nhận quyền sử dụng đất"}, {"id": "53f044078d0c40248bcbd40df78c39fa_e8", "label": "PROCEDURE_ACTION", "name": "Nhận quyền sử dụng đất, thuê lại đất", "value": "nhận quyền sử dụng đất; thuê lại đất"}], "Attributes_Measures": [], "Relationships": [{"source": "53f044078d0c40248bcbd40df78c39fa_e1", "type": "DEFINES", "target": "53f044078d0c40248bcbd40df78c39fa_e2"}, {"source": "53f044078d0c40248bcbd40df78c39fa_e4", "type": "EXECUTES_ACTION", "target": "53f044078d0c40248bcbd40df78c39fa_e7"}, {"source": "53f044078d0c40248bcbd40df78c39fa_e3", "type": "EXECUTES_ACTION", "target": "53f044078d0c40248bcbd40df78c39fa_e8"}, {"source": "53f044078d0c40248bcbd40df78c39fa_e3", "type": "MEETS_CONDITION", "target": "53f044078d0c40248bcbd40df78c39fa_e6"}], "metadata": {"document": "6049ddc3bab6450e84e2f022458b8b53", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "53f044078d0c40248bcbd40df78c39fa"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n3. Cá nhân trong nước, người Việt Nam định cư ở nước ngoài là công dân Việt Nam (sau đây gọi là cá nhân);"}
{"Level_3_Foundations": [{"id": "df632e8dd8784cd38db6ba14730549f2_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e2", "label": "SUBJECT", "name": "Cộng đồng dân cư", "value": "Cộng đồng dân cư"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e4", "label": "STANDARD_CONDITION", "name": "Sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận", "value": "đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e5", "label": "DOCUMENT_RECORD", "name": "Các loại Giấy chứng nhận liên quan đến quyền sử dụng đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; Giấy chứng nhận quyền sử dụng đất; Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở; Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất"}], "Level_2_Rules_Actions": [{"id": "df632e8dd8784cd38db6ba14730549f2_e6", "label": "RIGHT_OBLIGATION", "name": "Được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất", "value": "được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e7", "label": "RIGHT_OBLIGATION", "name": "Nhận quyền sử dụng đất", "value": "nhận quyền sử dụng đất"}, {"id": "df632e8dd8784cd38db6ba14730549f2_e8", "label": "RIGHT_OBLIGATION", "name": "Thuê lại đất", "value": "thuê lại đất theo quy định của Luật này"}], "Attributes_Measures": [], "Relationships": [{"source": "df632e8dd8784cd38db6ba14730549f2_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e6"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e7"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e8"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e1", "type": "MEETS_CONDITION", "target": "df632e8dd8784cd38db6ba14730549f2_e4"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e6"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e7"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "df632e8dd8784cd38db6ba14730549f2_e8"}, {"source": "df632e8dd8784cd38db6ba14730549f2_e2", "type": "MEETS_CONDITION", "target": "df632e8dd8784cd38db6ba14730549f2_e4"}], "metadata": {"document": "6049ddc3bab6450e84e2f022458b8b53", "phan": null, "chuong": null, "muc": null, "dieu": "4", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "df632e8dd8784cd38db6ba14730549f2"}, "original_content": "Điều 4. Người sử dụng đất\nNgười sử dụng đất được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất; đang sử dụng đất ổn định, đủ điều kiện cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất mà chưa được Nhà nước cấp Giấy chứng nhận quyền sử dụng đất, Giấy chứng nhận quyền sở hữu nhà ở và quyền sử dụng đất ở, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất, Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất; nhận quyền sử dụng đất; thuê lại đất theo quy định của Luật này, bao gồm:\n4. Cộng đồng dân cư;"}
