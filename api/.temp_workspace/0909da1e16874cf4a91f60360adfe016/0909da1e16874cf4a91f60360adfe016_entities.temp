{"Level_3_Foundations": [{"id": "433c502db42f4b5c91c17a44810c6af8_e1", "label": "SUBJECT", "name": "Cơ quan nhà nước", "value": "Cơ quan nhà nước"}, {"id": "433c502db42f4b5c91c17a44810c6af8_e2", "label": "LEGAL_CONCEPT", "name": "Đối tượng áp dụng", "value": "Điều 2. Đối tượng áp dụng"}], "Level_2_Rules_Actions": [{"id": "433c502db42f4b5c91c17a44810c6af8_e3", "label": "RIGHT_OBLIGATION", "name": "Thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai", "value": "thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai"}, {"id": "433c502db42f4b5c91c17a44810c6af8_e4", "label": "RIGHT_OBLIGATION", "name": "Thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai", "value": "thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "433c502db42f4b5c91c17a44810c6af8_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "433c502db42f4b5c91c17a44810c6af8_e3"}, {"source": "433c502db42f4b5c91c17a44810c6af8_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "433c502db42f4b5c91c17a44810c6af8_e4"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "433c502db42f4b5c91c17a44810c6af8"}, "original_content": "Điều 2. Đối tượng áp dụng\n1. Cơ quan nhà nước thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai, thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai."}
{"Level_3_Foundations": [{"id": "3cabb3c120864dc48ac6e92edd9ae9b1_e1", "label": "SUBJECT", "name": "Quốc hội", "value": "Quốc hội"}, {"id": "3cabb3c120864dc48ac6e92edd9ae9b1_e2", "label": "DOCUMENT_RECORD", "name": "Luật Đất đai (Luật số 31/2024/QH15)", "value": "Luật số: 31/2024/QH15, LUẬT ĐẤT ĐAI"}, {"id": "3cabb3c120864dc48ac6e92edd9ae9b1_e3", "label": "DOCUMENT_RECORD", "name": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam", "value": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam"}, {"id": "3cabb3c120864dc48ac6e92edd9ae9b1_e4", "label": "STANDARD_CONDITION", "name": "Căn cứ Hiến pháp", "value": "Căn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam"}], "Level_2_Rules_Actions": [{"id": "3cabb3c120864dc48ac6e92edd9ae9b1_e5", "label": "PROCEDURE_ACTION", "name": "Ban hành Luật Đất đai", "value": "Quốc hội ban hành Luật Đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "3cabb3c120864dc48ac6e92edd9ae9b1_e1", "type": "EXECUTES_ACTION", "target": "3cabb3c120864dc48ac6e92edd9ae9b1_e5"}, {"source": "3cabb3c120864dc48ac6e92edd9ae9b1_e5", "type": "MEETS_CONDITION", "target": "3cabb3c120864dc48ac6e92edd9ae9b1_e4"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "Phần mở đầu", "khoan": null, "diem": null, "type": "PREAMBLE", "chunk_uuid": "3cabb3c120864dc48ac6e92edd9ae9b1"}, "original_content": "**QUỐC HỘI**\n**CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM**\n**Độc lập - Tự do - Hạnh phúc**\n\nLuật số: 31/2024/QH15\n\n**LUẬT**\n**ĐẤT ĐAI**\n\nCăn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam;\nQuốc hội ban hành Luật Đất đai.\n\n## Chương I. QUY ĐỊNH CHUNG"}
{"Level_3_Foundations": [{"id": "192cec0249d84c53b0ebd4ad44812169_e1", "label": "DOCUMENT_RECORD", "name": "Luật này", "value": "Luật này"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e2", "label": "LEGAL_CONCEPT", "name": "Chế độ sở hữu đất đai", "value": "chế độ sở hữu đất đai"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e4", "label": "LEGAL_CONCEPT", "name": "Chế độ quản lý và sử dụng đất đai", "value": "chế độ quản lý và sử dụng đất đai"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e5", "label": "SUBJECT", "name": "Công dân", "value": "công dân"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e6", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e7", "label": "OBJECT_EQUIPMENT", "name": "Đất đai thuộc lãnh thổ Việt Nam", "value": "đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam"}], "Level_2_Rules_Actions": [{"id": "192cec0249d84c53b0ebd4ad44812169_e8", "label": "RIGHT_OBLIGATION", "name": "Quyền hạn và trách nhiệm của Nhà nước về đất đai", "value": "quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai"}, {"id": "192cec0249d84c53b0ebd4ad44812169_e9", "label": "RIGHT_OBLIGATION", "name": "Quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai", "value": "quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "192cec0249d84c53b0ebd4ad44812169_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "192cec0249d84c53b0ebd4ad44812169_e8"}, {"source": "192cec0249d84c53b0ebd4ad44812169_e5", "type": "HAS_RIGHT_OBLIGATION", "target": "192cec0249d84c53b0ebd4ad44812169_e9"}, {"source": "192cec0249d84c53b0ebd4ad44812169_e6", "type": "HAS_RIGHT_OBLIGATION", "target": "192cec0249d84c53b0ebd4ad44812169_e9"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "1", "khoan": null, "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "192cec0249d84c53b0ebd4ad44812169"}, "original_content": "Điều 1. Phạm vi điều chỉnh\nLuật này quy định về chế độ sở hữu đất đai, quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai, chế độ quản lý và sử dụng đất đai, quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "296b41033d6549079297edb008bd9804_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "296b41033d6549079297edb008bd9804"}, "original_content": "Điều 2. Đối tượng áp dụng\n2. Người sử dụng đất."}
{"Level_3_Foundations": [{"id": "ec30f74126d94be791d05972e32b3e2e_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ địa chính", "value": "Bản đồ địa chính"}, {"id": "ec30f74126d94be791d05972e32b3e2e_e2", "label": "DEFINITION", "name": "Định nghĩa Bản đồ địa chính", "value": "Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}, {"id": "ec30f74126d94be791d05972e32b3e2e_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "ec30f74126d94be791d05972e32b3e2e_e1", "type": "DEFINES", "target": "ec30f74126d94be791d05972e32b3e2e_e2"}, {"source": "ec30f74126d94be791d05972e32b3e2e_e3", "type": "HAS_AUTHORITY", "target": "ec30f74126d94be791d05972e32b3e2e_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "ec30f74126d94be791d05972e32b3e2e"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n1. Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}
{"Level_3_Foundations": [{"id": "0355d72dd23e4626b7dccfd03c60e0d5_e1", "label": "DOCUMENT_RECORD", "name": "Điều 2, Khoản 3, 0909da1e16874cf4a91f60360adfe016", "value": "Điều 2. Đối tượng áp dụng\n3. Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}, {"id": "0355d72dd23e4626b7dccfd03c60e0d5_e2", "label": "SUBJECT", "name": "Đối tượng khác liên quan đến quản lý, sử dụng đất đai", "value": "Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "0355d72dd23e4626b7dccfd03c60e0d5"}, "original_content": "Điều 2. Đối tượng áp dụng\n3. Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}
{"Level_3_Foundations": [{"id": "5b7393e4b822475bb224cfd92bfbc8bc_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "5b7393e4b822475bb224cfd92bfbc8bc_e2", "label": "LEGAL_CONCEPT", "name": "Bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất"}, {"id": "5b7393e4b822475bb224cfd92bfbc8bc_e3", "label": "DEFINITION", "name": "Định nghĩa Bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "5b7393e4b822475bb224cfd92bfbc8bc_e2", "type": "DEFINES", "target": "5b7393e4b822475bb224cfd92bfbc8bc_e3"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5b7393e4b822475bb224cfd92bfbc8bc"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n3. Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}
{"Level_3_Foundations": [{"id": "9530bb72596f4e9092f6ad3b7b12d77a_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất"}, {"id": "9530bb72596f4e9092f6ad3b7b12d77a_e2", "label": "DEFINITION", "name": "Định nghĩa Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "9530bb72596f4e9092f6ad3b7b12d77a_e1", "type": "DEFINES", "target": "9530bb72596f4e9092f6ad3b7b12d77a_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9530bb72596f4e9092f6ad3b7b12d77a"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n2. Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}
{"Level_3_Foundations": [{"id": "b4f78c99eefe4d04a1311a7f503c9692_e1", "label": "LEGAL_CONCEPT", "name": "Bảo vệ, cải tạo, phục hồi đất", "value": "Bảo vệ, cải tạo, phục hồi đất"}, {"id": "b4f78c99eefe4d04a1311a7f503c9692_e2", "label": "DEFINITION", "name": "Định nghĩa bảo vệ, cải tạo, phục hồi đất", "value": "Bảo vệ, cải tạo, phục hồi đất là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "b4f78c99eefe4d04a1311a7f503c9692_e1", "type": "DEFINES", "target": "b4f78c99eefe4d04a1311a7f503c9692_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "b4f78c99eefe4d04a1311a7f503c9692"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n4. Bảo vệ, cải tạo, phục hồi đất là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}
{"Level_3_Foundations": [{"id": "1dfee61af1da471ab41f2acfbfc51316_e1", "label": "LEGAL_CONCEPT", "name": "Chi phí đầu tư vào đất còn lại", "value": "Chi phí đầu tư vào đất còn lại"}, {"id": "1dfee61af1da471ab41f2acfbfc51316_e2", "label": "DEFINITION", "name": "Định nghĩa chi phí đầu tư vào đất còn lại", "value": "Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}, {"id": "1dfee61af1da471ab41f2acfbfc51316_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "1dfee61af1da471ab41f2acfbfc51316_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "1dfee61af1da471ab41f2acfbfc51316_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 7, Văn bản 0909da1e16874cf4a91f60360adfe016", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "1dfee61af1da471ab41f2acfbfc51316_e1", "type": "DEFINES", "target": "1dfee61af1da471ab41f2acfbfc51316_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "7", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "1dfee61af1da471ab41f2acfbfc51316"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}
{"Level_3_Foundations": [{"id": "d996041729684d028199d08724e7c474_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "d996041729684d028199d08724e7c474_e2", "label": "LEGAL_CONCEPT", "name": "Cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp"}, {"id": "d996041729684d028199d08724e7c474_e3", "label": "DEFINITION", "name": "Định nghĩa cá nhân trực tiếp sản xuất nông nghiệp", "value": "Trong Luật này, các từ ngữ dưới đây được hiểu như sau:\n6. Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}, {"id": "d996041729684d028199d08724e7c474_e4", "label": "STANDARD_CONDITION", "name": "Được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp", "value": "đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp"}, {"id": "d996041729684d028199d08724e7c474_e5", "label": "STANDARD_CONDITION", "name": "Nhận chuyển quyền sử dụng đất nông nghiệp", "value": "nhận chuyển quyền sử dụng đất nông nghiệp"}, {"id": "d996041729684d028199d08724e7c474_e6", "label": "STANDARD_CONDITION", "name": "Có thu nhập từ sản xuất nông nghiệp trên đất theo quy định của Chính phủ", "value": "có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ"}, {"id": "d996041729684d028199d08724e7c474_e7", "label": "SUBJECT", "name": "Chính phủ", "value": "Chính phủ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "d996041729684d028199d08724e7c474_e2", "type": "DEFINES", "target": "d996041729684d028199d08724e7c474_e3"}, {"source": "d996041729684d028199d08724e7c474_e2", "type": "MEETS_CONDITION", "target": "d996041729684d028199d08724e7c474_e4"}, {"source": "d996041729684d028199d08724e7c474_e2", "type": "MEETS_CONDITION", "target": "d996041729684d028199d08724e7c474_e5"}, {"source": "d996041729684d028199d08724e7c474_e2", "type": "MEETS_CONDITION", "target": "d996041729684d028199d08724e7c474_e6"}, {"source": "d996041729684d028199d08724e7c474_e7", "type": "HAS_AUTHORITY", "target": "d996041729684d028199d08724e7c474_e6"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "6", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "d996041729684d028199d08724e7c474"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n6. Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}
{"Level_3_Foundations": [{"id": "e0e9813eb78f4fb1bb33d23bc917d32e_e1", "label": "LEGAL_CONCEPT", "name": "Bồi thường về đất", "value": "Bồi thường về đất"}, {"id": "e0e9813eb78f4fb1bb33d23bc917d32e_e2", "label": "DEFINITION", "name": "Định nghĩa bồi thường về đất", "value": "Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}, {"id": "e0e9813eb78f4fb1bb33d23bc917d32e_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "e0e9813eb78f4fb1bb33d23bc917d32e_e4", "label": "SUBJECT", "name": "Người có đất thu hồi", "value": "người có đất thu hồi"}], "Level_2_Rules_Actions": [{"id": "e0e9813eb78f4fb1bb33d23bc917d32e_e5", "label": "RIGHT_OBLIGATION", "name": "Trả lại giá trị quyền sử dụng đất thu hồi", "value": "trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi"}], "Attributes_Measures": [], "Relationships": [{"source": "e0e9813eb78f4fb1bb33d23bc917d32e_e1", "type": "DEFINES", "target": "e0e9813eb78f4fb1bb33d23bc917d32e_e2"}, {"source": "e0e9813eb78f4fb1bb33d23bc917d32e_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "e0e9813eb78f4fb1bb33d23bc917d32e_e5"}, {"source": "e0e9813eb78f4fb1bb33d23bc917d32e_e4", "type": "HAS_RIGHT_OBLIGATION", "target": "e0e9813eb78f4fb1bb33d23bc917d32e_e5"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e0e9813eb78f4fb1bb33d23bc917d32e"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n5. Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}
{"Level_3_Foundations": [{"id": "5cbfa0532d37416fb848669e76ceaef3_e1", "label": "LEGAL_CONCEPT", "name": "Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư)"}, {"id": "5cbfa0532d37416fb848669e76ceaef3_e2", "label": "DEFINITION", "name": "Định nghĩa Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "5cbfa0532d37416fb848669e76ceaef3_e1", "type": "DEFINES", "target": "5cbfa0532d37416fb848669e76ceaef3_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "10", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "5cbfa0532d37416fb848669e76ceaef3"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n10. Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư) là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "1d5cb9a491ab4a71ac98f014684697e7_e1", "label": "LEGAL_CONCEPT", "name": "Chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất"}, {"id": "1d5cb9a491ab4a71ac98f014684697e7_e2", "label": "DEFINITION", "name": "Định nghĩa chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}, {"id": "1d5cb9a491ab4a71ac98f014684697e7_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 8, Luật 0909da1e16874cf4a91f60360adfe016", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n8. Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}, {"id": "1d5cb9a491ab4a71ac98f014684697e7_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "1d5cb9a491ab4a71ac98f014684697e7_e1", "type": "DEFINES", "target": "1d5cb9a491ab4a71ac98f014684697e7_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "8", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "1d5cb9a491ab4a71ac98f014684697e7"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n8. Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}
{"Level_3_Foundations": [{"id": "3624aaedc840494f8fcd6deda3a2176e_e1", "label": "LEGAL_CONCEPT", "name": "Chiếm đất", "value": "Chiếm đất"}, {"id": "3624aaedc840494f8fcd6deda3a2176e_e2", "label": "DEFINITION", "name": "Định nghĩa chiếm đất", "value": "là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}, {"id": "3624aaedc840494f8fcd6deda3a2176e_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "3624aaedc840494f8fcd6deda3a2176e_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "3624aaedc840494f8fcd6deda3a2176e_e5", "label": "SUBJECT", "name": "Người sử dụng đất hợp pháp khác", "value": "người sử dụng đất hợp pháp khác"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "3624aaedc840494f8fcd6deda3a2176e_e1", "type": "DEFINES", "target": "3624aaedc840494f8fcd6deda3a2176e_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "9", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "3624aaedc840494f8fcd6deda3a2176e"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n9. Chiếm đất là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}
{"Level_3_Foundations": [{"id": "70534498bc4641f09e9fd71b2e7d5875_e1", "label": "LEGAL_CONCEPT", "name": "Chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất"}, {"id": "70534498bc4641f09e9fd71b2e7d5875_e2", "label": "DEFINITION", "name": "Định nghĩa Chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "70534498bc4641f09e9fd71b2e7d5875_e1", "type": "DEFINES", "target": "70534498bc4641f09e9fd71b2e7d5875_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "12", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "70534498bc4641f09e9fd71b2e7d5875"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n12. Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}
{"Level_3_Foundations": [{"id": "556ffee114af445c90675f605d29a942_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "556ffee114af445c90675f605d29a942_e2", "label": "LEGAL_CONCEPT", "name": "Chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất"}, {"id": "556ffee114af445c90675f605d29a942_e3", "label": "DEFINITION", "name": "Định nghĩa Chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}, {"id": "556ffee114af445c90675f605d29a942_e4", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "556ffee114af445c90675f605d29a942_e2", "type": "DEFINES", "target": "556ffee114af445c90675f605d29a942_e3"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "11", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "556ffee114af445c90675f605d29a942"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n11. Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "9c5d0aae5aa143feb828a7959b9b02bc_e1", "label": "LEGAL_CONCEPT", "name": "Cộng đồng dân cư", "value": "Cộng đồng dân cư"}, {"id": "9c5d0aae5aa143feb828a7959b9b02bc_e2", "label": "DEFINITION", "name": "Định nghĩa cộng đồng dân cư", "value": "Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}, {"id": "9c5d0aae5aa143feb828a7959b9b02bc_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "9c5d0aae5aa143feb828a7959b9b02bc_e1", "type": "DEFINES", "target": "9c5d0aae5aa143feb828a7959b9b02bc_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "13", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "9c5d0aae5aa143feb828a7959b9b02bc"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n13. Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "a490f87a237741a496a307ec15658e57_e1", "label": "LEGAL_CONCEPT", "name": "Đất đang có tranh chấp", "value": "Đất đang có tranh chấp"}, {"id": "a490f87a237741a496a307ec15658e57_e2", "label": "DEFINITION", "name": "Định nghĩa đất đang có tranh chấp", "value": "Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}, {"id": "a490f87a237741a496a307ec15658e57_e3", "label": "SUBJECT", "name": "Cơ quan có thẩm quyền", "value": "cơ quan có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a490f87a237741a496a307ec15658e57_e1", "type": "DEFINES", "target": "a490f87a237741a496a307ec15658e57_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "16", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a490f87a237741a496a307ec15658e57"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n16. Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}
{"Level_3_Foundations": [{"id": "dc7f924baa394d42b210fb1f3900fb8f_e1", "label": "LEGAL_CONCEPT", "name": "Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai"}, {"id": "dc7f924baa394d42b210fb1f3900fb8f_e2", "label": "DEFINITION", "name": "Định nghĩa Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}, {"id": "dc7f924baa394d42b210fb1f3900fb8f_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 14, Luật 0909da1e16874cf4a91f60360adfe016", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n14. Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "dc7f924baa394d42b210fb1f3900fb8f_e1", "type": "DEFINES", "target": "dc7f924baa394d42b210fb1f3900fb8f_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "14", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "dc7f924baa394d42b210fb1f3900fb8f"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n14. Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}
{"Level_3_Foundations": [{"id": "b320fc23136f45f7a37f937ddf9f517e_e1", "label": "LEGAL_CONCEPT", "name": "Đăng ký đất đai, tài sản gắn liền với đất", "value": "Đăng ký đất đai, tài sản gắn liền với đất"}, {"id": "b320fc23136f45f7a37f937ddf9f517e_e2", "label": "DEFINITION", "name": "Định nghĩa Đăng ký đất đai, tài sản gắn liền với đất", "value": "Đăng ký đất đai, tài sản gắn liền với đất là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}, {"id": "b320fc23136f45f7a37f937ddf9f517e_e3", "label": "SUBJECT", "name": "Người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất", "value": "người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất"}, {"id": "b320fc23136f45f7a37f937ddf9f517e_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [{"id": "b320fc23136f45f7a37f937ddf9f517e_e5", "label": "PROCEDURE_ACTION", "name": "Kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này"}], "Attributes_Measures": [], "Relationships": [{"source": "b320fc23136f45f7a37f937ddf9f517e_e1", "type": "DEFINES", "target": "b320fc23136f45f7a37f937ddf9f517e_e2"}, {"source": "b320fc23136f45f7a37f937ddf9f517e_e3", "type": "EXECUTES_ACTION", "target": "b320fc23136f45f7a37f937ddf9f517e_e5"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "15", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "b320fc23136f45f7a37f937ddf9f517e"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n15. Đăng ký đất đai, tài sản gắn liền với đất là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "3169f5e9ebdb4318b94120a057e4b66f_e1", "label": "LEGAL_CONCEPT", "name": "Giá đất", "value": "Giá đất"}, {"id": "3169f5e9ebdb4318b94120a057e4b66f_e2", "label": "DEFINITION", "name": "Định nghĩa giá đất", "value": "Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "3169f5e9ebdb4318b94120a057e4b66f_e1", "type": "DEFINES", "target": "3169f5e9ebdb4318b94120a057e4b66f_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "19", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "3169f5e9ebdb4318b94120a057e4b66f"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n19. Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}
{"Level_3_Foundations": [{"id": "d8b88ef536a04a1dab5a7a6cf3d4244c_e1", "label": "LEGAL_CONCEPT", "name": "Gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất"}, {"id": "d8b88ef536a04a1dab5a7a6cf3d4244c_e2", "label": "DEFINITION", "name": "Định nghĩa Gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}, {"id": "d8b88ef536a04a1dab5a7a6cf3d4244c_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [{"id": "d8b88ef536a04a1dab5a7a6cf3d4244c_e4", "label": "PROCEDURE_ACTION", "name": "Cho phép tiếp tục sử dụng đất khi hết thời hạn", "value": "cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng"}], "Attributes_Measures": [], "Relationships": [{"source": "d8b88ef536a04a1dab5a7a6cf3d4244c_e1", "type": "DEFINES", "target": "d8b88ef536a04a1dab5a7a6cf3d4244c_e2"}, {"source": "d8b88ef536a04a1dab5a7a6cf3d4244c_e3", "type": "EXECUTES_ACTION", "target": "d8b88ef536a04a1dab5a7a6cf3d4244c_e4"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "18", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "d8b88ef536a04a1dab5a7a6cf3d4244c"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n18. Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "c8383a6c605e42b9803c79c54cfe9b09_e1", "label": "LEGAL_CONCEPT", "name": "Điều chỉnh thời hạn sử dụng đất", "value": "Điều chỉnh thời hạn sử dụng đất"}, {"id": "c8383a6c605e42b9803c79c54cfe9b09_e2", "label": "DEFINITION", "name": "Định nghĩa điều chỉnh thời hạn sử dụng đất", "value": "Điều chỉnh thời hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}, {"id": "c8383a6c605e42b9803c79c54cfe9b09_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "c8383a6c605e42b9803c79c54cfe9b09_e4", "label": "DOCUMENT_RECORD", "name": "Điều 3 Luật này", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "c8383a6c605e42b9803c79c54cfe9b09_e1", "type": "DEFINES", "target": "c8383a6c605e42b9803c79c54cfe9b09_e2"}], "metadata": {"document": "0909da1e16874cf4a91f60360adfe016", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "17", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "c8383a6c605e42b9803c79c54cfe9b09"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n17. Điều chỉnh thời hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}
