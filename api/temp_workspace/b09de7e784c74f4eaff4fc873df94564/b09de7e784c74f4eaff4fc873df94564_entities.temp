{"Level_3_Foundations": [{"id": "fa342f1263624d0282f4d3a95a7ec01e_e1", "label": "SUBJECT", "name": "Cơ quan nhà nước", "value": "Cơ quan nhà nước"}], "Level_2_Rules_Actions": [{"id": "fa342f1263624d0282f4d3a95a7ec01e_e2", "label": "RIGHT_OBLIGATION", "name": "Thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai", "value": "thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai"}, {"id": "fa342f1263624d0282f4d3a95a7ec01e_e3", "label": "RIGHT_OBLIGATION", "name": "Thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai", "value": "thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "fa342f1263624d0282f4d3a95a7ec01e_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "fa342f1263624d0282f4d3a95a7ec01e_e2"}, {"source": "fa342f1263624d0282f4d3a95a7ec01e_e1", "type": "HAS_RIGHT_OBLIGATION", "target": "fa342f1263624d0282f4d3a95a7ec01e_e3"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "fa342f1263624d0282f4d3a95a7ec01e"}, "original_content": "Điều 2. Đối tượng áp dụng\n1. Cơ quan nhà nước thực hiện quyền hạn và trách nhiệm đại diện chủ sở hữu toàn dân về đất đai, thực hiện nhiệm vụ thống nhất quản lý nhà nước về đất đai."}
{"Level_3_Foundations": [{"id": "860fa802dc6847f5852d829f00699fce_e1", "label": "SUBJECT", "name": "Quốc hội", "value": "Quốc hội"}, {"id": "860fa802dc6847f5852d829f00699fce_e2", "label": "DOCUMENT_RECORD", "name": "Luật Đất đai số 31/2024/QH15", "value": "Luật số: 31/2024/QH15, LUẬT ĐẤT ĐAI"}, {"id": "860fa802dc6847f5852d829f00699fce_e3", "label": "DOCUMENT_RECORD", "name": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam", "value": "Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam"}, {"id": "860fa802dc6847f5852d829f00699fce_e4", "label": "STANDARD_CONDITION", "name": "Căn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam", "value": "Căn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam"}], "Level_2_Rules_Actions": [{"id": "860fa802dc6847f5852d829f00699fce_e5", "label": "PROCEDURE_ACTION", "name": "Ban hành Luật Đất đai", "value": "Quốc hội ban hành Luật Đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "860fa802dc6847f5852d829f00699fce_e1", "type": "EXECUTES_ACTION", "target": "860fa802dc6847f5852d829f00699fce_e5"}, {"source": "860fa802dc6847f5852d829f00699fce_e5", "type": "MEETS_CONDITION", "target": "860fa802dc6847f5852d829f00699fce_e4"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "Phần mở đầu", "khoan": null, "diem": null, "type": "PREAMBLE", "chunk_uuid": "860fa802dc6847f5852d829f00699fce"}, "original_content": "QUỐC HỘI\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\nLuật số: 31/2024/QH15\n\n**LUẬT**\n**ĐẤT ĐAI**\n\nCăn cứ Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam;\nQuốc hội ban hành Luật Đất đai.\n\n## Chương I\nQUY ĐỊNH CHUNG"}
{"Level_3_Foundations": [{"id": "afa778486262419fba53f572631ea133_e1", "label": "LEGAL_CONCEPT", "name": "Chế độ sở hữu đất đai", "value": "chế độ sở hữu đất đai"}, {"id": "afa778486262419fba53f572631ea133_e2", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước đại diện chủ sở hữu toàn dân về đất đai"}, {"id": "afa778486262419fba53f572631ea133_e3", "label": "LEGAL_CONCEPT", "name": "Chế độ quản lý và sử dụng đất đai", "value": "chế độ quản lý và sử dụng đất đai"}, {"id": "afa778486262419fba53f572631ea133_e4", "label": "SUBJECT", "name": "Công dân", "value": "công dân"}, {"id": "afa778486262419fba53f572631ea133_e5", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "afa778486262419fba53f572631ea133_e6", "label": "OBJECT_EQUIPMENT", "name": "Đất đai thuộc lãnh thổ Việt Nam", "value": "đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam"}, {"id": "afa778486262419fba53f572631ea133_e7", "label": "DOCUMENT_RECORD", "name": "Điều 1 Luật Đất đai - Phạm vi điều chỉnh", "value": "Điều 1. Phạm vi điều chỉnh\nLuật này quy định về chế độ sở hữu đất đai, quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai, chế độ quản lý và sử dụng đất đai, quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam."}], "Level_2_Rules_Actions": [{"id": "afa778486262419fba53f572631ea133_e8", "label": "RIGHT_OBLIGATION", "name": "Quyền hạn và trách nhiệm của Nhà nước về đất đai", "value": "quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai"}, {"id": "afa778486262419fba53f572631ea133_e9", "label": "RIGHT_OBLIGATION", "name": "Quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai", "value": "quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai"}], "Attributes_Measures": [], "Relationships": [{"source": "afa778486262419fba53f572631ea133_e2", "type": "HAS_RIGHT_OBLIGATION", "target": "afa778486262419fba53f572631ea133_e8"}, {"source": "afa778486262419fba53f572631ea133_e4", "type": "HAS_RIGHT_OBLIGATION", "target": "afa778486262419fba53f572631ea133_e9"}, {"source": "afa778486262419fba53f572631ea133_e5", "type": "HAS_RIGHT_OBLIGATION", "target": "afa778486262419fba53f572631ea133_e9"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "1", "khoan": null, "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "afa778486262419fba53f572631ea133"}, "original_content": "Điều 1. Phạm vi điều chỉnh\nLuật này quy định về chế độ sở hữu đất đai, quyền hạn và trách nhiệm của Nhà nước đại diện chủ sở hữu toàn dân về đất đai và thống nhất quản lý về đất đai, chế độ quản lý và sử dụng đất đai, quyền và nghĩa vụ của công dân, người sử dụng đất đối với đất đai thuộc lãnh thổ của nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "f42d66ec63c04e4882a83320ac15185b_e1", "label": "SUBJECT", "name": "Đối tượng khác liên quan đến quản lý, sử dụng đất đai", "value": "Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "f42d66ec63c04e4882a83320ac15185b"}, "original_content": "Điều 2. Đối tượng áp dụng\n3. Các đối tượng khác có liên quan đến việc quản lý, sử dụng đất đai."}
{"Level_3_Foundations": [{"id": "52104341158a4335a20370cca31b61af_e1", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "Người sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "2", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "52104341158a4335a20370cca31b61af"}, "original_content": "Điều 2. Đối tượng áp dụng\n2. Người sử dụng đất."}
{"Level_3_Foundations": [{"id": "a798fd7c5d834cc59d96246c3af0c5b4_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ địa chính", "value": "Bản đồ địa chính"}, {"id": "a798fd7c5d834cc59d96246c3af0c5b4_e2", "label": "DEFINITION", "name": "Định nghĩa bản đồ địa chính", "value": "Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}, {"id": "a798fd7c5d834cc59d96246c3af0c5b4_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a798fd7c5d834cc59d96246c3af0c5b4_e1", "type": "DEFINES", "target": "a798fd7c5d834cc59d96246c3af0c5b4_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "1", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a798fd7c5d834cc59d96246c3af0c5b4"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n1. Bản đồ địa chính là bản đồ thể hiện các thửa đất và các đối tượng địa lý có liên quan, lập theo đơn vị hành chính cấp xã hoặc theo đơn vị hành chính cấp huyện nơi không thành lập đơn vị hành chính cấp xã, được cơ quan nhà nước có thẩm quyền xác nhận."}
{"Level_3_Foundations": [{"id": "dfc115ee16ad495b9c8e5b8df5fb905d_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất"}, {"id": "dfc115ee16ad495b9c8e5b8df5fb905d_e2", "label": "DEFINITION", "name": "Định nghĩa Bản đồ hiện trạng sử dụng đất", "value": "Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "dfc115ee16ad495b9c8e5b8df5fb905d_e1", "type": "DEFINES", "target": "dfc115ee16ad495b9c8e5b8df5fb905d_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "2", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "dfc115ee16ad495b9c8e5b8df5fb905d"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n2. Bản đồ hiện trạng sử dụng đất là bản đồ thể hiện sự phân bố các loại đất tại một thời điểm xác định, được lập theo từng đơn vị hành chính các cấp, theo từng vùng kinh tế - xã hội."}
{"Level_3_Foundations": [{"id": "a0a7b3bf0b114cdc9592d1484fd69dac_e1", "label": "LEGAL_CONCEPT", "name": "Bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất"}, {"id": "a0a7b3bf0b114cdc9592d1484fd69dac_e2", "label": "DEFINITION", "name": "Định nghĩa bản đồ quy hoạch sử dụng đất", "value": "Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a0a7b3bf0b114cdc9592d1484fd69dac_e1", "type": "DEFINES", "target": "a0a7b3bf0b114cdc9592d1484fd69dac_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "3", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a0a7b3bf0b114cdc9592d1484fd69dac"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n3. Bản đồ quy hoạch sử dụng đất là bản đồ được lập tại thời điểm đầu kỳ quy hoạch, thể hiện nội dung phân bố các loại đất tại thời điểm cuối kỳ quy hoạch của quy hoạch đó."}
{"Level_3_Foundations": [{"id": "c447515d733f4cb095e39906db1e9a2a_e1", "label": "LEGAL_CONCEPT", "name": "Bảo vệ, cải tạo, phục hồi đất", "value": "Bảo vệ, cải tạo, phục hồi đất"}, {"id": "c447515d733f4cb095e39906db1e9a2a_e2", "label": "DEFINITION", "name": "Định nghĩa bảo vệ, cải tạo, phục hồi đất", "value": "là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "c447515d733f4cb095e39906db1e9a2a_e1", "type": "DEFINES", "target": "c447515d733f4cb095e39906db1e9a2a_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "4", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "c447515d733f4cb095e39906db1e9a2a"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n4. Bảo vệ, cải tạo, phục hồi đất là việc áp dụng các biện pháp quản lý, kỹ thuật, cơ giới, sinh học, hữu cơ tác động vào đất để xử lý đất bị ô nhiễm, phục hồi đất bị thoái hóa."}
{"Level_3_Foundations": [{"id": "36b93ce262524b69ac4c27d3237ab725_e1", "label": "LEGAL_CONCEPT", "name": "Cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e2", "label": "DEFINITION", "name": "Định nghĩa cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}, {"id": "36b93ce262524b69ac4c27d3237ab725_e3", "label": "SUBJECT", "name": "Cá nhân trực tiếp sản xuất nông nghiệp", "value": "Cá nhân trực tiếp sản xuất nông nghiệp"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e4", "label": "STANDARD_CONDITION", "name": "Được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp", "value": "đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e5", "label": "STANDARD_CONDITION", "name": "Nhận chuyển quyền sử dụng đất nông nghiệp", "value": "nhận chuyển quyền sử dụng đất nông nghiệp"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e6", "label": "STANDARD_CONDITION", "name": "Có thu nhập từ sản xuất nông nghiệp trên đất theo quy định của Chính phủ", "value": "có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e7", "label": "SUBJECT", "name": "Chính phủ", "value": "Chính phủ"}, {"id": "36b93ce262524b69ac4c27d3237ab725_e8", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "36b93ce262524b69ac4c27d3237ab725_e1", "type": "DEFINES", "target": "36b93ce262524b69ac4c27d3237ab725_e2"}, {"source": "36b93ce262524b69ac4c27d3237ab725_e3", "type": "MEETS_CONDITION", "target": "36b93ce262524b69ac4c27d3237ab725_e4"}, {"source": "36b93ce262524b69ac4c27d3237ab725_e3", "type": "MEETS_CONDITION", "target": "36b93ce262524b69ac4c27d3237ab725_e5"}, {"source": "36b93ce262524b69ac4c27d3237ab725_e3", "type": "MEETS_CONDITION", "target": "36b93ce262524b69ac4c27d3237ab725_e6"}, {"source": "36b93ce262524b69ac4c27d3237ab725_e7", "type": "HAS_AUTHORITY", "target": "36b93ce262524b69ac4c27d3237ab725_e6"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "6", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "36b93ce262524b69ac4c27d3237ab725"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n6. Cá nhân trực tiếp sản xuất nông nghiệp là cá nhân đã được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất nông nghiệp; nhận chuyển quyền sử dụng đất nông nghiệp mà có thu nhập từ sản xuất nông nghiệp trên đất đó theo quy định của Chính phủ."}
{"Level_3_Foundations": [{"id": "583b8a8e6d374d0f8528c79f9cc33f88_e1", "label": "LEGAL_CONCEPT", "name": "Chi phí đầu tư vào đất còn lại", "value": "Chi phí đầu tư vào đất còn lại"}, {"id": "583b8a8e6d374d0f8528c79f9cc33f88_e2", "label": "DEFINITION", "name": "Định nghĩa chi phí đầu tư vào đất còn lại", "value": "Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}, {"id": "583b8a8e6d374d0f8528c79f9cc33f88_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "583b8a8e6d374d0f8528c79f9cc33f88_e4", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "583b8a8e6d374d0f8528c79f9cc33f88_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3 Khoản 7 Luật b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "583b8a8e6d374d0f8528c79f9cc33f88_e1", "type": "DEFINES", "target": "583b8a8e6d374d0f8528c79f9cc33f88_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "7", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "583b8a8e6d374d0f8528c79f9cc33f88"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n7. Chi phí đầu tư vào đất còn lại là chi phí hợp lý mà người sử dụng đất đã đầu tư trực tiếp vào đất phù hợp với mục đích sử dụng đất nhưng đến thời điểm Nhà nước thu hồi đất còn chưa thu hồi hết."}
{"Level_3_Foundations": [{"id": "58e08caea2514ad7bc10e8dd0acfd099_e1", "label": "LEGAL_CONCEPT", "name": "Bồi thường về đất", "value": "Bồi thường về đất"}, {"id": "58e08caea2514ad7bc10e8dd0acfd099_e2", "label": "DEFINITION", "name": "Định nghĩa bồi thường về đất", "value": "Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}, {"id": "58e08caea2514ad7bc10e8dd0acfd099_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "58e08caea2514ad7bc10e8dd0acfd099_e4", "label": "SUBJECT", "name": "Người có đất thu hồi", "value": "người có đất thu hồi"}], "Level_2_Rules_Actions": [{"id": "58e08caea2514ad7bc10e8dd0acfd099_e5", "label": "RIGHT_OBLIGATION", "name": "Trả lại giá trị quyền sử dụng đất thu hồi", "value": "trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi"}], "Attributes_Measures": [], "Relationships": [{"source": "58e08caea2514ad7bc10e8dd0acfd099_e1", "type": "DEFINES", "target": "58e08caea2514ad7bc10e8dd0acfd099_e2"}, {"source": "58e08caea2514ad7bc10e8dd0acfd099_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "58e08caea2514ad7bc10e8dd0acfd099_e5"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "5", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "58e08caea2514ad7bc10e8dd0acfd099"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n5. Bồi thường về đất là việc Nhà nước trả lại giá trị quyền sử dụng đất của diện tích đất thu hồi cho người có đất thu hồi."}
{"Level_3_Foundations": [{"id": "3aeba18173f94e81b267dd0b1f7f30c4_e1", "label": "LEGAL_CONCEPT", "name": "Chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất"}, {"id": "3aeba18173f94e81b267dd0b1f7f30c4_e2", "label": "DEFINITION", "name": "Định nghĩa chỉ tiêu sử dụng đất", "value": "Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "3aeba18173f94e81b267dd0b1f7f30c4_e1", "type": "DEFINES", "target": "3aeba18173f94e81b267dd0b1f7f30c4_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "8", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "3aeba18173f94e81b267dd0b1f7f30c4"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n8. Chỉ tiêu sử dụng đất là diện tích đất của từng loại đất được xác định trong quy hoạch, kế hoạch sử dụng đất các cấp do cơ quan nhà nước có thẩm quyền xác định để phân bổ trong quá trình lập quy hoạch, kế hoạch sử dụng đất."}
{"Level_3_Foundations": [{"id": "24799f626017438b9974ca1751227720_e1", "label": "LEGAL_CONCEPT", "name": "Chiếm đất", "value": "Chiếm đất"}, {"id": "24799f626017438b9974ca1751227720_e2", "label": "DEFINITION", "name": "Định nghĩa về chiếm đất", "value": "Chiếm đất là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}, {"id": "24799f626017438b9974ca1751227720_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 9, Luật b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ\n9. Chiếm đất là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "24799f626017438b9974ca1751227720_e1", "type": "DEFINES", "target": "24799f626017438b9974ca1751227720_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "9", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "24799f626017438b9974ca1751227720"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n9. Chiếm đất là việc sử dụng đất do Nhà nước đã quản lý mà chưa được cơ quan nhà nước có thẩm quyền cho phép hoặc sử dụng đất của người sử dụng đất hợp pháp khác mà chưa được người đó cho phép."}
{"Level_3_Foundations": [{"id": "d702ffc1595e4d0c9aa0a8ae271259b1_e1", "label": "LEGAL_CONCEPT", "name": "Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư)"}, {"id": "d702ffc1595e4d0c9aa0a8ae271259b1_e2", "label": "DEFINITION", "name": "Định nghĩa Chủ đầu tư dự án đầu tư có sử dụng đất", "value": "là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "d702ffc1595e4d0c9aa0a8ae271259b1_e1", "type": "DEFINES", "target": "d702ffc1595e4d0c9aa0a8ae271259b1_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "10", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "d702ffc1595e4d0c9aa0a8ae271259b1"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n10. Chủ đầu tư dự án đầu tư có sử dụng đất (sau đây gọi là chủ đầu tư) là nhà đầu tư theo quy định của pháp luật về đầu tư, pháp luật có liên quan đã được lựa chọn để thực hiện dự án đầu tư có sử dụng đất và được giao đất, cho thuê đất, chuyển mục đích sử dụng đất theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "e055380838924ed9a93eacfcb2642f29_e1", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}, {"id": "e055380838924ed9a93eacfcb2642f29_e2", "label": "LEGAL_CONCEPT", "name": "Chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất"}, {"id": "e055380838924ed9a93eacfcb2642f29_e3", "label": "DEFINITION", "name": "Định nghĩa chuyển quyền sử dụng đất", "value": "Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "e055380838924ed9a93eacfcb2642f29_e2", "type": "DEFINES", "target": "e055380838924ed9a93eacfcb2642f29_e3"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "12", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "e055380838924ed9a93eacfcb2642f29"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n12. Chuyển quyền sử dụng đất là việc chuyển giao quyền sử dụng đất từ người này sang người khác thông qua hình thức chuyển đổi, chuyển nhượng, thừa kế, tặng cho quyền sử dụng đất, góp vốn bằng quyền sử dụng đất."}
{"Level_3_Foundations": [{"id": "921e5c7061be4d2eafa4ebaa1887b47d_e1", "label": "LEGAL_CONCEPT", "name": "Chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất"}, {"id": "921e5c7061be4d2eafa4ebaa1887b47d_e2", "label": "DEFINITION", "name": "Định nghĩa chuyển mục đích sử dụng đất", "value": "Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}, {"id": "921e5c7061be4d2eafa4ebaa1887b47d_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "921e5c7061be4d2eafa4ebaa1887b47d_e1", "type": "DEFINES", "target": "921e5c7061be4d2eafa4ebaa1887b47d_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "11", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "921e5c7061be4d2eafa4ebaa1887b47d"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n11. Chuyển mục đích sử dụng đất là việc người sử dụng đất được thay đổi từ mục đích sử dụng đất này sang mục đích sử dụng đất khác theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "664cdd3ac62c47faa67feb0e6fe6aac9_e1", "label": "LEGAL_CONCEPT", "name": "Cộng đồng dân cư", "value": "Cộng đồng dân cư"}, {"id": "664cdd3ac62c47faa67feb0e6fe6aac9_e2", "label": "DEFINITION", "name": "Định nghĩa cộng đồng dân cư", "value": "Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}, {"id": "664cdd3ac62c47faa67feb0e6fe6aac9_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "664cdd3ac62c47faa67feb0e6fe6aac9_e1", "type": "DEFINES", "target": "664cdd3ac62c47faa67feb0e6fe6aac9_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "13", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "664cdd3ac62c47faa67feb0e6fe6aac9"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n13. Cộng đồng dân cư là cộng đồng người Việt Nam sinh sống trên cùng địa bàn thôn, làng, ấp, bản, bon, buôn, phum, sóc, tổ dân phố và điểm dân cư tương tự có cùng phong tục, tập quán hoặc có chung dòng họ trên lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam."}
{"Level_3_Foundations": [{"id": "4a625b7cfb734d6bb3973df0d4dd3f10_e1", "label": "LEGAL_CONCEPT", "name": "Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai"}, {"id": "4a625b7cfb734d6bb3973df0d4dd3f10_e2", "label": "DEFINITION", "name": "Định nghĩa Cơ sở dữ liệu quốc gia về đất đai", "value": "Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "4a625b7cfb734d6bb3973df0d4dd3f10_e1", "type": "DEFINES", "target": "4a625b7cfb734d6bb3973df0d4dd3f10_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "14", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "4a625b7cfb734d6bb3973df0d4dd3f10"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n14. Cơ sở dữ liệu quốc gia về đất đai là tập hợp các cơ sở dữ liệu đất đai trong đó dữ liệu được sắp xếp, tổ chức để truy cập, khai thác, chia sẻ, quản lý và cập nhật thông qua phương tiện điện tử."}
{"Level_3_Foundations": [{"id": "ba884ed31d2743aebbe4451927da89af_e1", "label": "LEGAL_CONCEPT", "name": "Đất đang có tranh chấp", "value": "Đất đang có tranh chấp"}, {"id": "ba884ed31d2743aebbe4451927da89af_e2", "label": "DEFINITION", "name": "Định nghĩa đất đang có tranh chấp", "value": "Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}, {"id": "ba884ed31d2743aebbe4451927da89af_e3", "label": "SUBJECT", "name": "Cơ quan có thẩm quyền", "value": "cơ quan có thẩm quyền"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "ba884ed31d2743aebbe4451927da89af_e1", "type": "DEFINES", "target": "ba884ed31d2743aebbe4451927da89af_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "16", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "ba884ed31d2743aebbe4451927da89af"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n16. Đất đang có tranh chấp là thửa đất có tranh chấp đất đai mà đang trong quá trình được cơ quan có thẩm quyền giải quyết."}
{"Level_3_Foundations": [{"id": "4cbe9dbd9a8149ed85b22cf27718e529_e1", "label": "LEGAL_CONCEPT", "name": "Đăng ký đất đai, tài sản gắn liền với đất", "value": "Đăng ký đất đai, tài sản gắn liền với đất"}, {"id": "4cbe9dbd9a8149ed85b22cf27718e529_e2", "label": "DEFINITION", "name": "Định nghĩa đăng ký đất đai, tài sản gắn liền với đất", "value": "là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}, {"id": "4cbe9dbd9a8149ed85b22cf27718e529_e3", "label": "SUBJECT", "name": "Người sử dụng đất, người sở hữu tài sản, người được giao quản lý đất", "value": "người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất"}, {"id": "4cbe9dbd9a8149ed85b22cf27718e529_e4", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}], "Level_2_Rules_Actions": [{"id": "4cbe9dbd9a8149ed85b22cf27718e529_e5", "label": "PROCEDURE_ACTION", "name": "Kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này"}], "Attributes_Measures": [], "Relationships": [{"source": "4cbe9dbd9a8149ed85b22cf27718e529_e1", "type": "DEFINES", "target": "4cbe9dbd9a8149ed85b22cf27718e529_e2"}, {"source": "4cbe9dbd9a8149ed85b22cf27718e529_e3", "type": "EXECUTES_ACTION", "target": "4cbe9dbd9a8149ed85b22cf27718e529_e5"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "15", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "4cbe9dbd9a8149ed85b22cf27718e529"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n15. Đăng ký đất đai, tài sản gắn liền với đất là việc người sử dụng đất, người sở hữu tài sản gắn liền với đất, người được giao quản lý đất kê khai quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất với cơ quan nhà nước có thẩm quyền để được ghi nhận theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "992d4f2e32234d8eac7307a9c9de1d05_e1", "label": "LEGAL_CONCEPT", "name": "Giá đất", "value": "Giá đất"}, {"id": "992d4f2e32234d8eac7307a9c9de1d05_e2", "label": "DEFINITION", "name": "Định nghĩa giá đất", "value": "Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}, {"id": "992d4f2e32234d8eac7307a9c9de1d05_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "992d4f2e32234d8eac7307a9c9de1d05_e1", "type": "DEFINES", "target": "992d4f2e32234d8eac7307a9c9de1d05_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "19", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "992d4f2e32234d8eac7307a9c9de1d05"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n19. Giá đất là giá trị của quyền sử dụng đất tính bằng tiền trên một đơn vị diện tích đất."}
{"Level_3_Foundations": [{"id": "eab35b1f4b154c90acb15fb0104ab4f3_e1", "label": "LEGAL_CONCEPT", "name": "Điều chỉnh thời hạn sử dụng đất", "value": "Điều chỉnh thời hạn sử dụng đất"}, {"id": "eab35b1f4b154c90acb15fb0104ab4f3_e2", "label": "DEFINITION", "name": "Định nghĩa điều chỉnh thời hạn sử dụng đất", "value": "là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}, {"id": "eab35b1f4b154c90acb15fb0104ab4f3_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "eab35b1f4b154c90acb15fb0104ab4f3_e4", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [{"id": "eab35b1f4b154c90acb15fb0104ab4f3_e5", "label": "PROCEDURE_ACTION", "name": "Cho phép thay đổi thời hạn sử dụng đất", "value": "cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất"}], "Attributes_Measures": [], "Relationships": [{"source": "eab35b1f4b154c90acb15fb0104ab4f3_e1", "type": "DEFINES", "target": "eab35b1f4b154c90acb15fb0104ab4f3_e2"}, {"source": "eab35b1f4b154c90acb15fb0104ab4f3_e3", "type": "EXECUTES_ACTION", "target": "eab35b1f4b154c90acb15fb0104ab4f3_e5"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "17", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "eab35b1f4b154c90acb15fb0104ab4f3"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n17. Điều chỉnh thời hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép thay đổi thời hạn sử dụng đất trong quá trình sử dụng đất."}
{"Level_3_Foundations": [{"id": "a7cfc2bb89e949cd9185a1eabb0c6e02_e1", "label": "LEGAL_CONCEPT", "name": "Gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất"}, {"id": "a7cfc2bb89e949cd9185a1eabb0c6e02_e2", "label": "DEFINITION", "name": "Định nghĩa về gia hạn sử dụng đất", "value": "Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}, {"id": "a7cfc2bb89e949cd9185a1eabb0c6e02_e3", "label": "SUBJECT", "name": "Cơ quan nhà nước có thẩm quyền", "value": "cơ quan nhà nước có thẩm quyền"}, {"id": "a7cfc2bb89e949cd9185a1eabb0c6e02_e4", "label": "DOCUMENT_RECORD", "name": "Điều 3 Khoản 18 Luật b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n18. Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a7cfc2bb89e949cd9185a1eabb0c6e02_e1", "type": "DEFINES", "target": "a7cfc2bb89e949cd9185a1eabb0c6e02_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "18", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a7cfc2bb89e949cd9185a1eabb0c6e02"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n18. Gia hạn sử dụng đất là việc cơ quan nhà nước có thẩm quyền cho phép tiếp tục sử dụng đất khi hết thời hạn theo mục đích đang sử dụng theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "57ee7f93d67c478c8380895067551527_e1", "label": "LEGAL_CONCEPT", "name": "Giá trị quyền sử dụng đất", "value": "Giá trị quyền sử dụng đất"}, {"id": "57ee7f93d67c478c8380895067551527_e2", "label": "DEFINITION", "name": "Định nghĩa giá trị quyền sử dụng đất", "value": "Giá trị quyền sử dụng đất là giá trị bằng tiền của quyền sử dụng đất đối với một diện tích đất, loại đất tại thời điểm được xác định với thời hạn sử dụng đã được xác định."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "57ee7f93d67c478c8380895067551527_e1", "type": "DEFINES", "target": "57ee7f93d67c478c8380895067551527_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "20", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "57ee7f93d67c478c8380895067551527"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n20. Giá trị quyền sử dụng đất là giá trị bằng tiền của quyền sử dụng đất đối với một diện tích đất, loại đất tại thời điểm được xác định với thời hạn sử dụng đã được xác định."}
{"Level_3_Foundations": [{"id": "a69e5b99ce1848a38f2de7c06d073cb3_e1", "label": "LEGAL_CONCEPT", "name": "Góp vốn bằng quyền sử dụng đất", "value": "Góp vốn bằng quyền sử dụng đất"}, {"id": "a69e5b99ce1848a38f2de7c06d073cb3_e2", "label": "DEFINITION", "name": "Định nghĩa Góp vốn bằng quyền sử dụng đất", "value": "Góp vốn bằng quyền sử dụng đất là sự thỏa thuận giữa các bên về chuyển quyền sử dụng đất thông qua việc góp quyền sử dụng đất để tạo thành vốn điều lệ của tổ chức kinh tế, bao gồm góp vốn để thành lập tổ chức kinh tế hoặc góp thêm vốn điều lệ của tổ chức kinh tế đã được thành lập."}, {"id": "a69e5b99ce1848a38f2de7c06d073cb3_e3", "label": "SUBJECT", "name": "Tổ chức kinh tế", "value": "tổ chức kinh tế"}, {"id": "a69e5b99ce1848a38f2de7c06d073cb3_e4", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "a69e5b99ce1848a38f2de7c06d073cb3_e1", "type": "DEFINES", "target": "a69e5b99ce1848a38f2de7c06d073cb3_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "22", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "a69e5b99ce1848a38f2de7c06d073cb3"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n22. Góp vốn bằng quyền sử dụng đất là sự thỏa thuận giữa các bên về chuyển quyền sử dụng đất thông qua việc góp quyền sử dụng đất để tạo thành vốn điều lệ của tổ chức kinh tế, bao gồm góp vốn để thành lập tổ chức kinh tế hoặc góp thêm vốn điều lệ của tổ chức kinh tế đã được thành lập."}
{"Level_3_Foundations": [{"id": "324b055546344d138968b2ed44afcbe3_e1", "label": "LEGAL_CONCEPT", "name": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "324b055546344d138968b2ed44afcbe3_e2", "label": "DEFINITION", "name": "Định nghĩa Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "là chứng thư pháp lý để Nhà nước xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp của người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất."}, {"id": "324b055546344d138968b2ed44afcbe3_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "324b055546344d138968b2ed44afcbe3_e4", "label": "SUBJECT", "name": "Người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất"}, {"id": "324b055546344d138968b2ed44afcbe3_e5", "label": "OBJECT_EQUIPMENT", "name": "Tài sản gắn liền với đất", "value": "Tài sản gắn liền với đất"}, {"id": "324b055546344d138968b2ed44afcbe3_e6", "label": "DEFINITION", "name": "Định nghĩa Tài sản gắn liền với đất", "value": "là nhà ở, công trình xây dựng gắn liền với đất theo quy định của pháp luật."}, {"id": "324b055546344d138968b2ed44afcbe3_e7", "label": "DOCUMENT_RECORD", "name": "Giấy chứng nhận về quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất", "value": "Giấy chứng nhận về quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất theo quy định của các luật có liên quan"}, {"id": "324b055546344d138968b2ed44afcbe3_e8", "label": "STANDARD_CONDITION", "name": "Có giá trị pháp lý tương đương Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất", "value": "có giá trị pháp lý tương đương như Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất tại Luật này."}], "Level_2_Rules_Actions": [{"id": "324b055546344d138968b2ed44afcbe3_e9", "label": "RIGHT_OBLIGATION", "name": "Quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp", "value": "quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp"}, {"id": "324b055546344d138968b2ed44afcbe3_e10", "label": "PROCEDURE_ACTION", "name": "Xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp", "value": "xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp"}], "Attributes_Measures": [], "Relationships": [{"source": "324b055546344d138968b2ed44afcbe3_e1", "type": "DEFINES", "target": "324b055546344d138968b2ed44afcbe3_e2"}, {"source": "324b055546344d138968b2ed44afcbe3_e3", "type": "EXECUTES_ACTION", "target": "324b055546344d138968b2ed44afcbe3_e10"}, {"source": "324b055546344d138968b2ed44afcbe3_e4", "type": "HAS_RIGHT_OBLIGATION", "target": "324b055546344d138968b2ed44afcbe3_e9"}, {"source": "324b055546344d138968b2ed44afcbe3_e5", "type": "DEFINES", "target": "324b055546344d138968b2ed44afcbe3_e6"}, {"source": "324b055546344d138968b2ed44afcbe3_e7", "type": "MEETS_CONDITION", "target": "324b055546344d138968b2ed44afcbe3_e8"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "21", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "324b055546344d138968b2ed44afcbe3"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n21. Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là chứng thư pháp lý để Nhà nước xác nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất hợp pháp của người có quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất. Tài sản gắn liền với đất được cấp Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất là nhà ở, công trình xây dựng gắn liền với đất theo quy định của pháp luật. Giấy chứng nhận về quyền sử dụng đất, quyền sở hữu nhà ở và tài sản khác gắn liền với đất theo quy định của các luật có\n\nliên quan được thực hiện theo quy định của Luật này có giá trị pháp lý tương đương như Giấy chứng nhận quyền sử dụng đất, quyền sở hữu tài sản gắn liền với đất tại Luật này."}
{"Level_3_Foundations": [{"id": "f3ef41752ebb444d911b255843a4314d_e1", "label": "LEGAL_CONCEPT", "name": "Hệ thống thông tin quốc gia về đất đai", "value": "Hệ thống thông tin quốc gia về đất đai"}, {"id": "f3ef41752ebb444d911b255843a4314d_e2", "label": "DEFINITION", "name": "Định nghĩa Hệ thống thông tin quốc gia về đất đai", "value": "Hệ thống thông tin quốc gia về đất đai là hệ thống tổng hợp các yếu tố hạ tầng kỹ thuật công nghệ thông tin, phần mềm, dữ liệu được xây dựng thành một hệ thống tập trung, thống nhất trên phạm vi cả nước để quản lý, vận hành, cập nhật, khai thác thông tin đất đai."}, {"id": "f3ef41752ebb444d911b255843a4314d_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "f3ef41752ebb444d911b255843a4314d_e1", "type": "DEFINES", "target": "f3ef41752ebb444d911b255843a4314d_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "23", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "f3ef41752ebb444d911b255843a4314d"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n23. Hệ thống thông tin quốc gia về đất đai là hệ thống tổng hợp các yếu tố hạ tầng kỹ thuật công nghệ thông tin, phần mềm, dữ liệu được xây dựng thành một hệ thống tập trung, thống nhất trên phạm vi cả nước để quản lý, vận hành, cập nhật, khai thác thông tin đất đai."}
{"Level_3_Foundations": [{"id": "716e493f212144d2be731ca68036ddf3_e1", "label": "LEGAL_CONCEPT", "name": "Hộ gia đình sử dụng đất", "value": "Hộ gia đình sử dụng đất"}, {"id": "716e493f212144d2be731ca68036ddf3_e2", "label": "DEFINITION", "name": "Định nghĩa Hộ gia đình sử dụng đất", "value": "Hộ gia đình sử dụng đất là những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình, đang sống chung và có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất trước ngày Luật này có hiệu lực thi hành."}, {"id": "716e493f212144d2be731ca68036ddf3_e3", "label": "STANDARD_CONDITION", "name": "Có quan hệ hôn nhân, huyết thống, nuôi dưỡng", "value": "những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình"}, {"id": "716e493f212144d2be731ca68036ddf3_e4", "label": "STANDARD_CONDITION", "name": "Đang sống chung", "value": "đang sống chung"}, {"id": "716e493f212144d2be731ca68036ddf3_e5", "label": "STANDARD_CONDITION", "name": "Có quyền sử dụng đất chung tại thời điểm được Nhà nước giao, cho thuê, công nhận, nhận chuyển quyền sử dụng đất", "value": "có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất trước ngày Luật này có hiệu lực thi hành"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "716e493f212144d2be731ca68036ddf3_e1", "type": "DEFINES", "target": "716e493f212144d2be731ca68036ddf3_e2"}, {"source": "716e493f212144d2be731ca68036ddf3_e1", "type": "MEETS_CONDITION", "target": "716e493f212144d2be731ca68036ddf3_e3"}, {"source": "716e493f212144d2be731ca68036ddf3_e1", "type": "MEETS_CONDITION", "target": "716e493f212144d2be731ca68036ddf3_e4"}, {"source": "716e493f212144d2be731ca68036ddf3_e1", "type": "MEETS_CONDITION", "target": "716e493f212144d2be731ca68036ddf3_e5"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "25", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "716e493f212144d2be731ca68036ddf3"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n25. Hộ gia đình sử dụng đất là những người có quan hệ hôn nhân, huyết thống, nuôi dưỡng theo quy định của pháp luật về hôn nhân và gia đình, đang sống chung và có quyền sử dụng đất chung tại thời điểm được Nhà nước giao đất, cho thuê đất, công nhận quyền sử dụng đất, nhận chuyển quyền sử dụng đất trước ngày Luật này có hiệu lực thi hành."}
{"Level_3_Foundations": [{"id": "bc209ce610cc44f6a365942ee14c75b5_e1", "label": "LEGAL_CONCEPT", "name": "Hỗ trợ khi Nhà nước thu hồi đất", "value": "Hỗ trợ khi Nhà nước thu hồi đất"}, {"id": "bc209ce610cc44f6a365942ee14c75b5_e2", "label": "DEFINITION", "name": "Định nghĩa Hỗ trợ khi Nhà nước thu hồi đất", "value": "Hỗ trợ khi Nhà nước thu hồi đất là chính sách của Nhà nước nhằm trợ giúp cho người có đất thu hồi, chủ sở hữu tài sản gắn liền với đất để ổn định đời sống, sản xuất và phát triển ngoài các khoản đã bồi thường theo quy định của Luật này."}, {"id": "bc209ce610cc44f6a365942ee14c75b5_e3", "label": "SUBJECT", "name": "Người có đất thu hồi", "value": "người có đất thu hồi"}, {"id": "bc209ce610cc44f6a365942ee14c75b5_e4", "label": "SUBJECT", "name": "Chủ sở hữu tài sản gắn liền với đất", "value": "chủ sở hữu tài sản gắn liền với đất"}, {"id": "bc209ce610cc44f6a365942ee14c75b5_e5", "label": "DOCUMENT_RECORD", "name": "Điều 3. Giải thích từ ngữ", "value": "Điều 3. Giải thích từ ngữ"}], "Level_2_Rules_Actions": [{"id": "bc209ce610cc44f6a365942ee14c75b5_e6", "label": "RIGHT_OBLIGATION", "name": "Được trợ giúp để ổn định đời sống, sản xuất và phát triển", "value": "trợ giúp cho người có đất thu hồi, chủ sở hữu tài sản gắn liền với đất để ổn định đời sống, sản xuất và phát triển"}], "Attributes_Measures": [], "Relationships": [{"source": "bc209ce610cc44f6a365942ee14c75b5_e1", "type": "DEFINES", "target": "bc209ce610cc44f6a365942ee14c75b5_e2"}, {"source": "bc209ce610cc44f6a365942ee14c75b5_e3", "type": "HAS_RIGHT_OBLIGATION", "target": "bc209ce610cc44f6a365942ee14c75b5_e6"}, {"source": "bc209ce610cc44f6a365942ee14c75b5_e4", "type": "HAS_RIGHT_OBLIGATION", "target": "bc209ce610cc44f6a365942ee14c75b5_e6"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "24", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "bc209ce610cc44f6a365942ee14c75b5"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n24. Hỗ trợ khi Nhà nước thu hồi đất là chính sách của Nhà nước nhằm trợ giúp cho người có đất thu hồi, chủ sở hữu tài sản gắn liền với đất để ổn định đời sống, sản xuất và phát triển ngoài các khoản đã bồi thường theo quy định của Luật này."}
{"Level_3_Foundations": [{"id": "b2f5cdd51f93495f9ea68c42116ffa4b_e1", "label": "LEGAL_CONCEPT", "name": "Hủy hoại đất", "value": "Hủy hoại đất"}, {"id": "b2f5cdd51f93495f9ea68c42116ffa4b_e2", "label": "DEFINITION", "name": "Định nghĩa hủy hoại đất", "value": "Hủy hoại đất là hành vi làm biến dạng địa hình, làm suy giảm chất lượng đất, gây ô nhiễm đất mà làm mất hoặc giảm khả năng sử dụng đất theo mục đích đã được xác định."}, {"id": "b2f5cdd51f93495f9ea68c42116ffa4b_e3", "label": "DOCUMENT_RECORD", "name": "Điều 3, Khoản 27, Luật b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ\n27. Hủy hoại đất là hành vi làm biến dạng địa hình, làm suy giảm chất lượng đất, gây ô nhiễm đất mà làm mất hoặc giảm khả năng sử dụng đất theo mục đích đã được xác định."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "b2f5cdd51f93495f9ea68c42116ffa4b_e1", "type": "DEFINES", "target": "b2f5cdd51f93495f9ea68c42116ffa4b_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "27", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "b2f5cdd51f93495f9ea68c42116ffa4b"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n27. Hủy hoại đất là hành vi làm biến dạng địa hình, làm suy giảm chất lượng đất, gây ô nhiễm đất mà làm mất hoặc giảm khả năng sử dụng đất theo mục đích đã được xác định."}
{"Level_3_Foundations": [{"id": "6aa6077956134c62888eda4f3278c292_e1", "label": "LEGAL_CONCEPT", "name": "Kế hoạch sử dụng đất", "value": "Kế hoạch sử dụng đất"}, {"id": "6aa6077956134c62888eda4f3278c292_e2", "label": "DEFINITION", "name": "Định nghĩa Kế hoạch sử dụng đất", "value": "Kế hoạch sử dụng đất là việc phân kỳ quy hoạch sử dụng đất theo thời gian để thực hiện."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "6aa6077956134c62888eda4f3278c292_e1", "type": "DEFINES", "target": "6aa6077956134c62888eda4f3278c292_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "28", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "6aa6077956134c62888eda4f3278c292"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n28. Kế hoạch sử dụng đất là việc phân kỳ quy hoạch sử dụng đất theo thời gian để thực hiện."}
{"Level_3_Foundations": [{"id": "441286339fd94261ba899ec7d2132e87_e1", "label": "LEGAL_CONCEPT", "name": "Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất", "value": "Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất"}, {"id": "441286339fd94261ba899ec7d2132e87_e2", "label": "DEFINITION", "name": "Định nghĩa Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất", "value": "là sự thỏa thuận giữa các bên, theo đó người sử dụng đất dùng quyền sử dụng đất của mình để hợp tác sản xuất, kinh doanh mà không làm thay đổi quyền sử dụng đất của người sử dụng đất."}, {"id": "441286339fd94261ba899ec7d2132e87_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "441286339fd94261ba899ec7d2132e87_e1", "type": "DEFINES", "target": "441286339fd94261ba899ec7d2132e87_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "26", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "441286339fd94261ba899ec7d2132e87"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n26. Hợp tác sản xuất, kinh doanh bằng quyền sử dụng đất là sự thỏa thuận giữa các bên, theo đó người sử dụng đất dùng quyền sử dụng đất của mình để hợp tác sản xuất, kinh doanh mà không làm thay đổi quyền sử dụng đất của người sử dụng đất."}
{"Level_3_Foundations": [{"id": "82cdfda5b17b49e8a1e8efb29d798cbc_e1", "label": "LEGAL_CONCEPT", "name": "Lấn biển", "value": "Lấn biển"}, {"id": "82cdfda5b17b49e8a1e8efb29d798cbc_e2", "label": "DEFINITION", "name": "Định nghĩa Lấn biển", "value": "Lấn biển là việc mở rộng diện tích đất trong phạm vi từ đường mép nước biển thấp nhất trung bình trong nhiều năm về phía biển thuộc vùng biển Việt Nam."}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "82cdfda5b17b49e8a1e8efb29d798cbc_e1", "type": "DEFINES", "target": "82cdfda5b17b49e8a1e8efb29d798cbc_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "30", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "82cdfda5b17b49e8a1e8efb29d798cbc"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n30. Lấn biển là việc mở rộng diện tích đất trong phạm vi từ đường mép nước biển thấp nhất trung bình trong nhiều năm về phía biển thuộc vùng biển Việt Nam."}
{"Level_3_Foundations": [{"id": "482b00c3675d4a61bcce13fe7da2f6f4_e1", "label": "LEGAL_CONCEPT", "name": "Kiểm kê đất đai", "value": "Kiểm kê đất đai"}, {"id": "482b00c3675d4a61bcce13fe7da2f6f4_e2", "label": "DEFINITION", "name": "Định nghĩa kiểm kê đất đai", "value": "Kiểm kê đất đai là việc Nhà nước tổ chức điều tra, tổng hợp, đánh giá trên hồ sơ địa chính và trên thực địa về hiện trạng sử dụng đất tại thời điểm kiểm kê và biến động đất đai giữa 02 lần kiểm kê."}, {"id": "482b00c3675d4a61bcce13fe7da2f6f4_e3", "label": "SUBJECT", "name": "Nhà nước", "value": "Nhà nước"}, {"id": "482b00c3675d4a61bcce13fe7da2f6f4_e4", "label": "DOCUMENT_RECORD", "name": "Hồ sơ địa chính", "value": "hồ sơ địa chính"}], "Level_2_Rules_Actions": [], "Attributes_Measures": [], "Relationships": [{"source": "482b00c3675d4a61bcce13fe7da2f6f4_e1", "type": "DEFINES", "target": "482b00c3675d4a61bcce13fe7da2f6f4_e2"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "29", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "482b00c3675d4a61bcce13fe7da2f6f4"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n29. Kiểm kê đất đai là việc Nhà nước tổ chức điều tra, tổng hợp, đánh giá trên hồ sơ địa chính và trên thực địa về hiện trạng sử dụng đất tại thời điểm kiểm kê và biến động đất đai giữa 02 lần kiểm kê."}
{"Level_3_Foundations": [{"id": "4efef67117664f938d0ae12db0d0f8fc_e1", "label": "LEGAL_CONCEPT", "name": "Lấn đất", "value": "Lấn đất"}, {"id": "4efef67117664f938d0ae12db0d0f8fc_e2", "label": "DEFINITION", "name": "Định nghĩa Lấn đất", "value": "Lấn đất là việc người sử dụng đất chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng mà không được cơ quan nhà nước có thẩm quyền cho phép hoặc không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép."}, {"id": "4efef67117664f938d0ae12db0d0f8fc_e3", "label": "SUBJECT", "name": "Người sử dụng đất", "value": "người sử dụng đất"}, {"id": "4efef67117664f938d0ae12db0d0f8fc_e4", "label": "STANDARD_CONDITION", "name": "Không được cơ quan nhà nước có thẩm quyền cho phép", "value": "không được cơ quan nhà nước có thẩm quyền cho phép"}, {"id": "4efef67117664f938d0ae12db0d0f8fc_e5", "label": "STANDARD_CONDITION", "name": "Không được người sử dụng hợp pháp diện tích đất bị lấn cho phép", "value": "không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép"}, {"id": "4efef67117664f938d0ae12db0d0f8fc_e6", "label": "DOCUMENT_RECORD", "name": "Điều 3, b09de7e784c74f4eaff4fc873df94564", "value": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n31. Lấn đất là việc người sử dụng đất chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng mà không được cơ quan nhà nước có thẩm quyền cho phép hoặc không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép."}], "Level_2_Rules_Actions": [{"id": "4efef67117664f938d0ae12db0d0f8fc_e7", "label": "PROCEDURE_ACTION", "name": "Chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích", "value": "chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng"}], "Attributes_Measures": [], "Relationships": [{"source": "4efef67117664f938d0ae12db0d0f8fc_e1", "type": "DEFINES", "target": "4efef67117664f938d0ae12db0d0f8fc_e2"}, {"source": "4efef67117664f938d0ae12db0d0f8fc_e3", "type": "EXECUTES_ACTION", "target": "4efef67117664f938d0ae12db0d0f8fc_e7"}, {"source": "4efef67117664f938d0ae12db0d0f8fc_e7", "type": "MEETS_CONDITION", "target": "4efef67117664f938d0ae12db0d0f8fc_e4"}, {"source": "4efef67117664f938d0ae12db0d0f8fc_e7", "type": "MEETS_CONDITION", "target": "4efef67117664f938d0ae12db0d0f8fc_e5"}], "metadata": {"document": "b09de7e784c74f4eaff4fc873df94564", "phan": null, "chuong": null, "muc": null, "dieu": "3", "khoan": "31", "diem": null, "type": "LEGAL_RULE", "chunk_uuid": "4efef67117664f938d0ae12db0d0f8fc"}, "original_content": "Điều 3. Giải thích từ ngữ\nTrong Luật này, các từ ngữ dưới đây được hiểu như sau:\n31. Lấn đất là việc người sử dụng đất chuyển dịch mốc giới hoặc ranh giới thửa đất để mở rộng diện tích đất sử dụng mà không được cơ quan nhà nước có thẩm quyền cho phép hoặc không được người sử dụng hợp pháp diện tích đất bị lấn đó cho phép."}
