# Sao chép file này thành ".env" (cùng thư mục) và điền giá trị thật trước khi chạy.
# .env KHÔNG được commit lên Git (đã có trong .gitignore).

# Gemini API key - dùng cho: OCR dự phòng, trích xuất thực thể dự phòng,
# xây quan hệ liên văn bản (build_edges.py), và toàn bộ luồng chat thời gian thực.
API_KEY=

# Thông tin đăng nhập Neo4j (địa chỉ kết nối URI cấu hình trong backend/config.yaml).
USER_NEO4J=neo4j
PASSWORD_NEO4J=
